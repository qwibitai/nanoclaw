#!/bin/bash
# merge-pr — Merge a GitHub PR with CI wait logic and branch cleanup.
#
# Usage: merge-pr <pr-number> [--squash|--merge|--rebase] [--no-delete-branch]
#
# Edge cases handled:
#   - CI checks pending (waits with timeout)
#   - CI checks failing (clear error, does not merge)
#   - Branch deletion errors after merge (non-fatal warning)
#   - PR already merged (skip, report success)
#   - PR not found / closed (clear error)
#   - Merge strategy selection (squash default, merge, rebase)
set -euo pipefail

# ---------- defaults ----------
STRATEGY="squash"
DELETE_BRANCH=true
CI_TIMEOUT=300       # 5 minutes max wait for CI
CI_POLL_INTERVAL=10  # poll every 10 seconds
MAX_RETRIES=3        # retry attempts for transient merge failures
BACKOFF_BASE=2       # exponential backoff base (2^attempt seconds)
PR_NUMBER=""

# ---------- helpers ----------
die()  { echo "ERROR: $*" >&2; exit 1; }
warn() { echo "WARN: $*" >&2; }
info() { echo "INFO: $*"; }

usage() {
  cat <<EOF
Usage: merge-pr <pr-number> [--squash|--merge|--rebase] [--no-delete-branch]

Arguments:
  pr-number           The PR number to merge (required).

Options:
  --squash            Squash and merge (default).
  --merge             Create a merge commit.
  --rebase            Rebase and merge.
  --no-delete-branch  Keep the remote branch after merging.
  --ci-timeout <sec>  Max seconds to wait for CI (default: 300).
  -h, --help          Show this help message.
EOF
  exit 0
}

# ---------- arg parsing ----------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --squash)  STRATEGY="squash" ;;
    --merge)   STRATEGY="merge" ;;
    --rebase)  STRATEGY="rebase" ;;
    --no-delete-branch) DELETE_BRANCH=false ;;
    --ci-timeout) shift; CI_TIMEOUT="${1:-300}" ;;
    -h|--help) usage ;;
    -*)        die "Unknown option: $1" ;;
    *)
      if [[ -z "$PR_NUMBER" ]]; then
        # Validate that it looks like a number.
        [[ "$1" =~ ^[0-9]+$ ]] || die "PR number must be numeric, got: $1"
        PR_NUMBER="$1"
      else
        die "Unexpected argument: $1"
      fi
      ;;
  esac
  shift
done

[[ -z "$PR_NUMBER" ]] && die "PR number is required. Run 'merge-pr --help' for usage."

# ---------- prerequisite checks ----------
command -v gh >/dev/null 2>&1 || die "gh CLI is not installed. Install it: https://cli.github.com"
git rev-parse --git-dir >/dev/null 2>&1 || die "Not inside a git repository."

# ---------- PR state check ----------
PR_STATE=$(gh pr view "$PR_NUMBER" --json state --jq '.state' 2>/dev/null || true)

case "$PR_STATE" in
  MERGED)
    PR_URL_DISPLAY=$(gh pr view "$PR_NUMBER" --json url --jq '.url' 2>/dev/null || true)
    info "PR #$PR_NUMBER is already merged."
    info "View it at: ${PR_URL_DISPLAY:-gh pr view $PR_NUMBER --web}"
    exit 0
    ;;
  CLOSED)
    echo "" >&2
    echo "ERROR: PR #$PR_NUMBER is closed (not merged)." >&2
    echo "" >&2
    echo "  Next steps:" >&2
    echo "    - Re-open the PR:   gh pr reopen $PR_NUMBER" >&2
    echo "    - View PR details:  gh pr view $PR_NUMBER" >&2
    echo "    - Check the number: gh pr list --state all | grep $PR_NUMBER" >&2
    exit 1
    ;;
  OPEN)
    # Good — proceed.
    ;;
  "")
    echo "" >&2
    echo "ERROR: PR #$PR_NUMBER not found or API error." >&2
    echo "" >&2
    echo "  Check:" >&2
    echo "    - Is the PR number correct? gh pr list --state all" >&2
    echo "    - Are you in the right repo? gh repo view" >&2
    echo "    - Is GitHub auth working?   gh auth status" >&2
    exit 1
    ;;
  *)
    die "PR #$PR_NUMBER is in unexpected state: $PR_STATE"
    ;;
esac

# Capture branch names for later cleanup and error messages.
PR_BRANCH=$(gh pr view "$PR_NUMBER" --json headRefName --jq '.headRefName' 2>/dev/null || true)
BASE_BRANCH=$(gh pr view "$PR_NUMBER" --json baseRefName --jq '.baseRefName' 2>/dev/null || echo "main")
info "Merging PR #$PR_NUMBER (branch: ${PR_BRANCH:-unknown} -> ${BASE_BRANCH}, strategy: $STRATEGY)"

# ---------- CI check wait ----------
# Wait for required status checks to pass before merging.
WAITED=0
CI_API_FAILURES=0
MAX_CI_API_FAILURES=3

while [[ $WAITED -lt $CI_TIMEOUT ]]; do
  # gh pr checks returns exit code 1 if checks are failing/pending.
  # Capture exit code separately to distinguish API errors from check failures.
  CHECK_EXIT=0
  CHECK_OUTPUT=$(gh pr checks "$PR_NUMBER" 2>&1) || CHECK_EXIT=$?

  # Detect API/auth/network errors: if gh failed AND the output doesn't contain
  # typical check-status keywords (pass/fail/pending), it's likely an API error.
  if [[ $CHECK_EXIT -ne 0 ]]; then
    PASS_COUNT=$(echo "$CHECK_OUTPUT" | grep -c "pass" || true)
    FAIL_COUNT=$(echo "$CHECK_OUTPUT" | grep -c "fail" || true)
    PENDING_COUNT=$(echo "$CHECK_OUTPUT" | grep -c "pending\|queued\|in_progress" || true)

    if [[ $((PASS_COUNT + FAIL_COUNT + PENDING_COUNT)) -eq 0 ]]; then
      # No recognizable check statuses — this is an API/network error, not a check result.
      CI_API_FAILURES=$((CI_API_FAILURES + 1))
      warn "gh pr checks returned an error (attempt $CI_API_FAILURES/$MAX_CI_API_FAILURES): $CHECK_OUTPUT"
      if [[ $CI_API_FAILURES -ge $MAX_CI_API_FAILURES ]]; then
        die "gh pr checks failed $MAX_CI_API_FAILURES times due to API errors. Cannot verify CI status. Last output: $CHECK_OUTPUT"
      fi
      sleep "$CI_POLL_INTERVAL"
      WAITED=$((WAITED + CI_POLL_INTERVAL))
      continue
    fi
  fi

  # Reset API failure counter on successful check retrieval.
  CI_API_FAILURES=0

  # Count statuses — "pass", "fail", "pending".
  FAIL_COUNT=$(echo "$CHECK_OUTPUT" | grep -c "fail" || true)
  PENDING_COUNT=$(echo "$CHECK_OUTPUT" | grep -c "pending\|queued\|in_progress" || true)

  if [[ "$FAIL_COUNT" -gt 0 ]]; then
    echo "" >&2
    echo "ERROR: PR #$PR_NUMBER has failing CI checks:" >&2
    echo "$CHECK_OUTPUT" | grep -i "fail" | while IFS= read -r line; do
      echo "  $line" >&2
    done
    echo "" >&2
    echo "  Next steps:" >&2
    echo "    - View check details:  gh pr checks $PR_NUMBER" >&2
    echo "    - View PR in browser:  gh pr view $PR_NUMBER --web" >&2
    echo "    - Fix issues and push new commits to the PR branch" >&2
    exit 1
  fi

  if [[ "$PENDING_COUNT" -eq 0 ]]; then
    # No pending, no failing — checks either passed or there are none.
    break
  fi

  if [[ $WAITED -eq 0 ]]; then
    info "Waiting for CI checks to complete (timeout: ${CI_TIMEOUT}s)..."
  fi

  sleep "$CI_POLL_INTERVAL"
  WAITED=$((WAITED + CI_POLL_INTERVAL))
done

if [[ $WAITED -ge $CI_TIMEOUT ]]; then
  warn "CI checks did not complete within ${CI_TIMEOUT}s. Attempting merge anyway."
fi

# ---------- merge with retry + backoff ----------
MERGE_FLAG="--$STRATEGY"
DELETE_FLAG=""
if [[ "$DELETE_BRANCH" == true ]]; then
  DELETE_FLAG="--delete-branch"
fi

MERGE_ATTEMPT=0
MERGE_OUTPUT=""

while [[ $MERGE_ATTEMPT -lt $MAX_RETRIES ]]; do
  MERGE_ATTEMPT=$((MERGE_ATTEMPT + 1))

  MERGE_OUTPUT=$(gh pr merge "$PR_NUMBER" $MERGE_FLAG $DELETE_FLAG 2>&1) && break

  # Check if it was merged by someone else in the meantime.
  RECHECK_STATE=$(gh pr view "$PR_NUMBER" --json state --jq '.state' 2>/dev/null || true)
  if [[ "$RECHECK_STATE" == "MERGED" ]]; then
    info "PR #$PR_NUMBER was merged concurrently."
    exit 0
  fi

  # Non-retryable errors: permission denied, merge conflicts, branch protection.
  if echo "$MERGE_OUTPUT" | grep -qiE "merge conflict|protected branch|not authorized|permission denied|review required"; then
    echo "" >&2
    echo "ERROR: Cannot merge PR #$PR_NUMBER (non-retryable):" >&2
    echo "  $MERGE_OUTPUT" >&2
    echo "" >&2
    echo "  Next steps:" >&2
    if echo "$MERGE_OUTPUT" | grep -qi "merge conflict"; then
      echo "    - Resolve conflicts: git checkout $PR_BRANCH && git merge $BASE_BRANCH" >&2
    fi
    if echo "$MERGE_OUTPUT" | grep -qi "review required"; then
      echo "    - Get a review:     gh pr view $PR_NUMBER --web" >&2
    fi
    echo "    - View PR status:   gh pr view $PR_NUMBER" >&2
    exit 1
  fi

  if [[ $MERGE_ATTEMPT -lt $MAX_RETRIES ]]; then
    SLEEP=$((BACKOFF_BASE ** MERGE_ATTEMPT))
    warn "gh pr merge failed (attempt $MERGE_ATTEMPT/$MAX_RETRIES). Retrying in ${SLEEP}s..."
    warn "  Output: $MERGE_OUTPUT"
    sleep "$SLEEP"
  else
    echo "" >&2
    echo "ERROR: Failed to merge PR #$PR_NUMBER after $MAX_RETRIES attempts." >&2
    echo "  Last output: $MERGE_OUTPUT" >&2
    echo "" >&2
    echo "  Troubleshooting:" >&2
    echo "    - Check PR status:   gh pr view $PR_NUMBER" >&2
    echo "    - Check CI status:   gh pr checks $PR_NUMBER" >&2
    echo "    - Try manually:      gh pr merge $PR_NUMBER $MERGE_FLAG" >&2
    echo "    - Check GitHub auth: gh auth status" >&2
    exit 1
  fi
done

info "PR #$PR_NUMBER merged successfully ($STRATEGY)."

# ---------- branch cleanup ----------
# Handle branch deletion errors gracefully. The merge may have already
# deleted the remote branch, or deletion may fail due to branch protection.
if [[ "$DELETE_BRANCH" == true && -n "$PR_BRANCH" ]]; then
  # Clean up local branch reference if it exists.
  if git show-ref --verify --quiet "refs/heads/$PR_BRANCH" 2>/dev/null; then
    # Don't delete if we're currently on this branch.
    CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || true)
    if [[ "$CURRENT_BRANCH" == "$PR_BRANCH" ]]; then
      warn "Currently on branch '$PR_BRANCH'. Switching to main before cleanup."
      git checkout main 2>/dev/null || git checkout master 2>/dev/null || warn "Could not switch away from '$PR_BRANCH'."
    fi

    git branch -d "$PR_BRANCH" 2>/dev/null || {
      warn "Could not delete local branch '$PR_BRANCH'."
      warn "  This usually means it has unmerged local changes."
      warn "  To force-delete:  git branch -D $PR_BRANCH"
      warn "  To inspect first: git log --oneline main..$PR_BRANCH"
    }
  fi

  # Prune stale remote tracking refs.
  git remote prune origin 2>/dev/null || true
fi

# ---------- update local main ----------
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || true)
if [[ "$CURRENT_BRANCH" == "main" || "$CURRENT_BRANCH" == "master" ]]; then
  info "Pulling latest changes on $CURRENT_BRANCH..."
  git pull --ff-only 2>/dev/null || warn "Could not fast-forward $CURRENT_BRANCH."
fi

info "Done. PR #$PR_NUMBER merged via $STRATEGY."
