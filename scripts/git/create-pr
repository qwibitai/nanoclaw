#!/bin/bash
# create-pr — Create a GitHub PR from a dev-inbox branch with edge-case handling.
#
# Usage: create-pr <branch-name> [--title <title>] [--auto-merge]
#
# Edge cases handled:
#   - Worktree lock conflicts (suggests cleanup)
#   - No commits on branch vs base (clear error)
#   - Branch already has an open PR (returns existing URL)
#   - gh CLI API failures (retry with exponential backoff)
#   - Missing/invalid branch name (clear error)
set -euo pipefail

# ---------- defaults ----------
MAX_RETRIES=3
BACKOFF_BASE=2
TITLE=""
AUTO_MERGE=false
BASE_BRANCH="main"
BRANCH=""

# ---------- helpers ----------
die()  { echo "ERROR: $*" >&2; exit 1; }
warn() { echo "WARN: $*" >&2; }
info() { echo "INFO: $*"; }

usage() {
  cat <<EOF
Usage: create-pr <branch-name> [--title <title>] [--auto-merge] [--base <base>]

Arguments:
  branch-name       The branch to create a PR from (required).

Options:
  --title <title>   PR title. Defaults to the branch name, cleaned up.
  --auto-merge      Enable auto-merge on the PR after creation.
  --base <base>     Base branch to merge into (default: main).
  -h, --help        Show this help message.
EOF
  exit 0
}

# ---------- arg parsing ----------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --title)   shift; TITLE="${1:-}"; [[ -z "$TITLE" ]] && die "--title requires a value" ;;
    --auto-merge) AUTO_MERGE=true ;;
    --base)    shift; BASE_BRANCH="${1:-}"; [[ -z "$BASE_BRANCH" ]] && die "--base requires a value" ;;
    -h|--help) usage ;;
    -*)        die "Unknown option: $1" ;;
    *)
      [[ -z "$BRANCH" ]] && BRANCH="$1" || die "Unexpected argument: $1"
      ;;
  esac
  shift
done

[[ -z "$BRANCH" ]] && die "Branch name is required. Run 'create-pr --help' for usage."

# ---------- prerequisite checks ----------

# Ensure gh CLI is available.
command -v gh >/dev/null 2>&1 || die "gh CLI is not installed. Install it: https://cli.github.com"

# Ensure we're inside a git repository.
git rev-parse --git-dir >/dev/null 2>&1 || die "Not inside a git repository."

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ---------- branch name validation ----------
# Reject branch names that would cause git or shell problems.
if [[ "$BRANCH" =~ [[:space:]] ]]; then
  die "Branch name '$BRANCH' contains whitespace. Use hyphens or slashes instead."
fi
if [[ "$BRANCH" == *.lock || "$BRANCH" == *.. || "$BRANCH" =~ [\~\^:?*\[] ]]; then
  die "Branch name '$BRANCH' contains invalid git ref characters. See 'git check-ref-format --help'."
fi

# ---------- worktree lock detection ----------
# If a worktree is checked out on this branch, git operations may conflict.
# Detect and warn the user with a suggested fix.
WORKTREE_LIST="$(git worktree list --porcelain 2>/dev/null || true)"
if echo "$WORKTREE_LIST" | grep -q "branch refs/heads/${BRANCH}$"; then
  # Porcelain format emits: worktree <path>, HEAD <sha>, branch <ref> (in that order).
  # Use -B2 to capture the worktree line (2 lines before the branch line), then filter for it.
  WORKTREE_PATH=$(echo "$WORKTREE_LIST" | grep -B2 "branch refs/heads/${BRANCH}$" | grep '^worktree ' | sed 's/^worktree //')
  if [[ -n "$WORKTREE_PATH" ]]; then
    warn "Branch '$BRANCH' is checked out in worktree: $WORKTREE_PATH"
    warn "This may cause push/checkout conflicts during PR operations."
    warn ""
    warn "To resolve, either:"
    warn "  1. Remove the worktree:  git worktree remove '$WORKTREE_PATH'"
    warn "  2. Or unlock and prune:  git worktree unlock '$WORKTREE_PATH' && git worktree prune"
    warn ""
    warn "Continuing anyway — the PR can still be created from the remote branch."
  fi
fi

# ---------- branch existence check ----------
# Verify the branch exists locally or on the remote.
BRANCH_EXISTS_LOCAL=false
BRANCH_EXISTS_REMOTE=false

if git show-ref --verify --quiet "refs/heads/$BRANCH" 2>/dev/null; then
  BRANCH_EXISTS_LOCAL=true
fi

if git ls-remote --exit-code --heads origin "$BRANCH" >/dev/null 2>&1; then
  BRANCH_EXISTS_REMOTE=true
fi

if [[ "$BRANCH_EXISTS_LOCAL" == false && "$BRANCH_EXISTS_REMOTE" == false ]]; then
  die "Branch '$BRANCH' does not exist locally or on remote 'origin'."
fi

# ---------- commit verification ----------
# Ensure the branch has commits that differ from the base branch.
# Use the remote base if available, otherwise local.
if git show-ref --verify --quiet "refs/remotes/origin/$BASE_BRANCH" 2>/dev/null; then
  BASE_REF="origin/$BASE_BRANCH"
else
  BASE_REF="$BASE_BRANCH"
fi

# Determine branch ref to compare.
if [[ "$BRANCH_EXISTS_LOCAL" == true ]]; then
  BRANCH_REF="$BRANCH"
else
  BRANCH_REF="origin/$BRANCH"
fi

COMMIT_COUNT=$(git rev-list --count "$BASE_REF".."$BRANCH_REF" 2>/dev/null || echo "0")
if [[ "$COMMIT_COUNT" -eq 0 ]]; then
  echo "" >&2
  echo "ERROR: Branch '$BRANCH' has no commits ahead of '$BASE_BRANCH'. Nothing to create a PR for." >&2
  echo "" >&2
  echo "  To inspect the branch:" >&2
  echo "    git log --oneline $BASE_REF..$BRANCH_REF" >&2
  echo "" >&2
  echo "  If you expected commits, check:" >&2
  echo "    - Are commits on a different base? Try: git log --oneline --all --graph | head -20" >&2
  echo "    - Was the branch rebased or force-pushed? Try: git reflog show $BRANCH_REF | head -5" >&2
  exit 1
fi

info "Branch '$BRANCH' has $COMMIT_COUNT commit(s) ahead of '$BASE_BRANCH'."

# Show commit summary for verification.
info "Commits to be included in PR:"
git log --oneline "$BASE_REF".."$BRANCH_REF" 2>/dev/null | while IFS= read -r line; do
  echo "  $line"
done

# ---------- check for existing PR ----------
EXISTING_PR=$(gh pr list --head "$BRANCH" --base "$BASE_BRANCH" --state open --json number,url --jq '.[0].url' 2>/dev/null || true)
if [[ -n "$EXISTING_PR" ]]; then
  info "PR already exists: $EXISTING_PR"
  info "To update it, push new commits to '$BRANCH'."
  echo "$EXISTING_PR"
  exit 0
fi

# Also check if already merged.
MERGED_PR=$(gh pr list --head "$BRANCH" --base "$BASE_BRANCH" --state merged --json number,url --jq '.[0].url' 2>/dev/null || true)
if [[ -n "$MERGED_PR" ]]; then
  info "Branch '$BRANCH' was already merged: $MERGED_PR"
  info ""
  info "Next steps:"
  info "  - Delete the branch locally:   git branch -d $BRANCH"
  info "  - Delete the remote branch:    git push origin --delete $BRANCH"
  info "  - Or start fresh from main:    git checkout main && git pull"
  echo "$MERGED_PR"
  exit 0
fi

# ---------- push branch to remote if needed ----------
if [[ "$BRANCH_EXISTS_REMOTE" == false ]]; then
  info "Pushing '$BRANCH' to origin..."
  PUSH_OUTPUT=""
  PUSH_ATTEMPT=0
  while [[ $PUSH_ATTEMPT -lt $MAX_RETRIES ]]; do
    PUSH_ATTEMPT=$((PUSH_ATTEMPT + 1))
    PUSH_OUTPUT=$(git push -u origin "$BRANCH" 2>&1) && break

    if [[ $PUSH_ATTEMPT -lt $MAX_RETRIES ]]; then
      SLEEP=$((BACKOFF_BASE ** PUSH_ATTEMPT))
      warn "git push failed (attempt $PUSH_ATTEMPT/$MAX_RETRIES). Retrying in ${SLEEP}s..."
      sleep "$SLEEP"
    else
      echo "" >&2
      echo "ERROR: Failed to push '$BRANCH' to origin after $MAX_RETRIES attempts." >&2
      echo "  Last output: $PUSH_OUTPUT" >&2
      echo "" >&2
      echo "  Common fixes:" >&2
      echo "    - Check network connectivity" >&2
      echo "    - Verify remote access: git remote -v" >&2
      echo "    - Check auth: gh auth status" >&2
      exit 1
    fi
  done
fi

# ---------- derive PR title ----------
if [[ -z "$TITLE" ]]; then
  # Clean branch name into a human-readable title.
  # e.g. "dev-inbox/abc12345-feat/git-pr-helpers" -> "feat: git pr helpers"
  TITLE=$(echo "$BRANCH" \
    | sed 's|^dev-inbox/[a-f0-9]*-||' \
    | sed 's|^dispatch/[a-f0-9]*-||' \
    | sed 's|/|: |' \
    | sed 's/-/ /g')
fi

# ---------- create PR with retry + backoff ----------
ATTEMPT=0
PR_URL=""

while [[ $ATTEMPT -lt $MAX_RETRIES ]]; do
  ATTEMPT=$((ATTEMPT + 1))

  PR_URL=$(gh pr create \
    --head "$BRANCH" \
    --base "$BASE_BRANCH" \
    --title "$TITLE" \
    --body "Automated PR from dev-inbox branch \`$BRANCH\`." \
    2>&1) && break

  # Check if the error indicates the PR already exists (race condition).
  if echo "$PR_URL" | grep -qi "already exists"; then
    EXISTING=$(gh pr list --head "$BRANCH" --base "$BASE_BRANCH" --state open --json url --jq '.[0].url' 2>/dev/null || true)
    if [[ -n "$EXISTING" ]]; then
      info "PR was created concurrently: $EXISTING"
      echo "$EXISTING"
      exit 0
    fi
  fi

  if [[ $ATTEMPT -lt $MAX_RETRIES ]]; then
    SLEEP=$((BACKOFF_BASE ** ATTEMPT))
    warn "gh pr create failed (attempt $ATTEMPT/$MAX_RETRIES). Retrying in ${SLEEP}s..."
    sleep "$SLEEP"
  else
    echo "" >&2
    echo "ERROR: Failed to create PR after $MAX_RETRIES attempts." >&2
    echo "  Last output: $PR_URL" >&2
    echo "" >&2
    echo "  Troubleshooting:" >&2
    echo "    - Check GitHub auth:  gh auth status" >&2
    echo "    - Verify remote:      git remote -v" >&2
    echo "    - Try manually:       gh pr create --head '$BRANCH' --base '$BASE_BRANCH'" >&2
    exit 1
  fi
done

info "PR created: $PR_URL"

# ---------- auto-merge ----------
if [[ "$AUTO_MERGE" == true ]]; then
  PR_NUMBER=$(echo "$PR_URL" | grep -oE '[0-9]+$' || true)
  if [[ -n "$PR_NUMBER" ]]; then
    info "Enabling auto-merge on PR #$PR_NUMBER..."
    gh pr merge "$PR_NUMBER" --auto --squash 2>/dev/null \
      || warn "Could not enable auto-merge (may require branch protection rules)."
  fi
fi

echo "$PR_URL"
