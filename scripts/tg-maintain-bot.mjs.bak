#!/usr/bin/env node
/**
 * NanoClaw Maintenance Executor Bot
 *
 * Works under Kanae's supervision:
 * - Kanae (container agent) writes tasks to host-tasks/
 * - This bot executes them via Claude Code on the host
 * - Results written to host-tasks-done/ for Kanae to review
 *
 * Also: self-healing (auto-restart NanoClaw if it crashes),
 *       duplicate container cleanup, message backlog detection.
 */

import { execSync, spawn } from 'child_process';
import fs from 'fs';
import path from 'path';

const BOT_TOKEN = '8621132320:AAFcHZbPW-C3qROHKqww_K3_lHpXzoysNK4';
const OWNER_CHAT_ID = 8656923396;
const NC_DIR = process.env.HOME + '/nanoclaw';
const TASKS_DIR = `${NC_DIR}/store/host-tasks`;
const TASKS_DONE_DIR = `${NC_DIR}/store/host-tasks-done`;
const KANAE_JID = 'tg:-1003746091450';
const HEALTH_INTERVAL = 60_000;
const TASK_POLL_INTERVAL = 15_000;

let lastUpdateId = 0;
let knownTaskFiles = new Set();
let busy = false;

// ── Utilities ──

function run(cmd, timeout = 30000) {
  try {
    return execSync(cmd, { encoding: 'utf8', timeout }).trim();
  } catch (e) {
    return null;
  }
}

function runClaude(prompt, timeout = 600000) {
  return new Promise((resolve) => {
    const proc = spawn('claude', ['-p', '-', '--max-turns', '20', '--dangerously-skip-permissions'], {
      cwd: NC_DIR,
      env: { ...process.env, CLAUDECODE: '' },
    });
    proc.stdin.write(prompt);
    proc.stdin.end();
    let output = '';
    const timer = setTimeout(() => {
      proc.kill('SIGTERM');
      resolve({ output: output || '(timed out after 10min)', exitCode: 124 });
    }, timeout);
    proc.stdout.on('data', d => { output += d.toString(); });
    proc.stderr.on('data', d => { output += d.toString(); });
    proc.on('close', (code) => {
      clearTimeout(timer);
      resolve({ output: output.trim() || '(no output)', exitCode: code ?? 0 });
    });
    proc.on('error', (err) => {
      clearTimeout(timer);
      resolve({ output: output || `(process error: ${err.message})`, exitCode: 1 });
    });
  });
}

async function notify(text) {
  const url = `https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`;
  try {
    await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ chat_id: OWNER_CHAT_ID, text: text.slice(0, 4096) }),
    });
  } catch (e) {
    console.error('Notify failed:', e.message);
  }
}

// ── System context ──

function buildContext() {
  const pid = run('pgrep -f "nanoclaw/dist/index.js"') || 'NOT RUNNING';
  const containers = run('docker ps --filter "name=nanoclaw" --format "{{.Names}} — {{.Status}}" 2>/dev/null') || 'None';
  const groups = run(`sqlite3 ${NC_DIR}/store/messages.db "SELECT folder || '|' || jid || '|trigger=' || requires_trigger FROM registered_groups;" 2>/dev/null`) || 'None';
  const recentErrors = run(`grep "ERROR" ${NC_DIR}/logs/nanoclaw.log 2>/dev/null | tail -5 | sed 's/\\x1b\\[[0-9;]*m//g'`) || 'None';
  const portCheck = run('lsof -i :3001 -i :3002 2>/dev/null | grep LISTEN') || 'Ports free';
  const diskUsage = run('df -h / | tail -1') || 'Unknown';
  const recentCron = run(`sqlite3 ${NC_DIR}/store/messages.db "SELECT task_id, run_at, status FROM task_run_logs ORDER BY run_at DESC LIMIT 5;" 2>/dev/null`) || 'No recent runs';

  return `
你是 NanoClaw 的 host 执行 bot。你在 host 上运行，可以执行任何系统命令。
你的任务由 Kanae（维护监督者 Agent）委派。认真完成任务，输出清晰的结果。

## NanoClaw 系统架构
- 项目目录: ${NC_DIR}
- 源码: ${NC_DIR}/src/ (TypeScript)
- 编译: cd ${NC_DIR} && npx tsc
- 重启: kill $(pgrep -f "nanoclaw/dist/index.js"); sleep 2; cd ${NC_DIR} && node dist/index.js &>/dev/null &
- DB: ${NC_DIR}/store/messages.db (SQLite, better-sqlite3)
- .env: ${NC_DIR}/.env (TELEGRAM_BOTS 配置)
- 日志: ${NC_DIR}/logs/nanoclaw.log
- Agent 配置: ${NC_DIR}/groups/<folder>/CLAUDE.md
- 容器入口: ${NC_DIR}/container/agent-runner/src/index.ts (容器内编译，不要在 host 编译)
- mount 白名单: ~/.config/nanoclaw/mount-allowlist.json
- Credential proxy: port 3001
- Paper-search MCP: port 3002

## 注意事项
- registered_groups 表的 requires_trigger 默认 1，新增行后必须 UPDATE 为 0
- Telegram supergroup JID 格式: tg:-100XXXXXXXXXX
- 修改 src/ 后需要 npx tsc 编译再重启
- 不要修改 container/agent-runner/ 内的文件（容器启动时自己编译）

## 当前状态
- NanoClaw PID: ${pid}
- 容器: ${containers}
- 注册群组: ${groups}
- 端口: ${portCheck}
- 磁盘: ${diskUsage}
- 最近错误: ${recentErrors}
- 最近 cron: ${recentCron}
`.trim();
}

// ── Core: handle user message (owner DM, quick commands) ──

async function handleUserMessage(text) {
  if (busy) {
    await notify('⏳ 上一个任务还在跑，稍等...');
    return;
  }
  busy = true;

  try {
    await notify('🔍 分析中...');
    const context = buildContext();
    const prompt = `${context}

用户说: "${text}"

请分析问题或需求，然后直接执行修复/实现。
- 如果是 bug：查日志、查 DB、查代码，找到原因并修复
- 如果是新功能：修改源码，编译，重启 NanoClaw
- 如果需要重启 NanoClaw，直接执行
- 用中文简要回复你做了什么`;

    const { output } = await runClaude(prompt);
    await notify(`✅ Done\n\n${output.slice(-3500)}`);
  } catch (e) {
    await notify(`❌ Failed: ${e.message}`);
  } finally {
    busy = false;
  }
}

// ── Self-healing ──

let downCount = 0;

async function healthCheck() {
  const pid = run('pgrep -f "nanoclaw/dist/index.js"');
  if (!pid) {
    downCount++;
    if (downCount <= 3) {
      const portPid = run('lsof -ti :3001');
      if (portPid) {
        run(`kill -9 ${portPid}`);
        await new Promise(r => setTimeout(r, 1000));
      }
      run(`cd ${NC_DIR} && node dist/index.js &>/dev/null &`);
      await new Promise(r => setTimeout(r, 3000));
      const newPid = run('pgrep -f "nanoclaw/dist/index.js"');
      if (newPid) {
        await notify(`🔧 NanoClaw was down → auto-restarted (PID: ${newPid})`);
        downCount = 0;
      }
    } else if (downCount === 4) {
      await notify('🚨 NanoClaw crash loop — stopped auto-restart, needs investigation');
    }
  } else {
    downCount = 0;
  }

  // Duplicate container detection
  const containerList = run('docker ps --filter "name=nanoclaw-" --format "{{.Names}} {{.CreatedAt}}" 2>/dev/null');
  if (containerList) {
    const byGroup = {};
    for (const line of containerList.split('\n').filter(Boolean)) {
      const name = line.split(' ')[0];
      const match = name.match(/^nanoclaw-(.+)-\d+$/);
      if (!match) continue;
      const group = match[1];
      if (!byGroup[group]) byGroup[group] = [];
      byGroup[group].push(name);
    }
    for (const [group, containers] of Object.entries(byGroup)) {
      if (containers.length > 1) {
        containers.sort();
        const toKill = containers.slice(0, -1);
        for (const c of toKill) {
          run(`docker kill ${c} 2>/dev/null`);
        }
        await notify(`🔧 ${group}: killed ${toKill.length} duplicate container(s), kept ${containers[containers.length - 1]}`);
      }
    }
  }

  // Message backlog detection
  let lastAgentTs = {};
  try {
    const raw = run(`sqlite3 ${NC_DIR}/store/messages.db "SELECT value FROM router_state WHERE key = 'last_agent_timestamp';" 2>/dev/null`);
    if (raw) lastAgentTs = JSON.parse(raw);
  } catch { /* ignore */ }

  const groups = run(`sqlite3 ${NC_DIR}/store/messages.db "SELECT jid, folder FROM registered_groups;" 2>/dev/null`);
  if (groups) {
    for (const line of groups.split('\n').filter(Boolean)) {
      const [jid, folder] = line.split('|');
      const cursor = lastAgentTs[jid] || '';
      const backlog = run(`sqlite3 ${NC_DIR}/store/messages.db "
        SELECT COUNT(*), MIN(timestamp) FROM messages
        WHERE chat_jid = '${jid}' AND is_bot_message = 0
          AND timestamp > '${cursor}'
          AND timestamp < datetime('now', '-5 minutes');" 2>/dev/null`);
      if (backlog) {
        const [count, oldest] = backlog.split('|');
        if (parseInt(count) > 0) {
          await notify(`⚠️ ${folder}: ${count} unprocessed message(s) since ${oldest}`);
        }
      }
    }
  }
}

// ── Notify Kanae of task result (via DB insert, triggers NanoClaw message routing) ──

function notifyKanae(taskFile, status, summary) {
  const text = `📋 host-task 执行完毕\n任务: ${taskFile}\n状态: ${status}\n\n${summary.slice(0, 500)}\n\n请读取 /workspace/extra/host-tasks-done/${taskFile} 查看完整结果并审核。`;
  const msgId = `maintain-${Date.now()}-${Math.random().toString(36).slice(2, 6)}`;
  const ts = new Date().toISOString();
  // Escape single quotes for sqlite3
  const escaped = text.replace(/'/g, "''");
  const result = run(`sqlite3 "${NC_DIR}/store/messages.db" "INSERT OR REPLACE INTO messages (id, chat_jid, sender, sender_name, content, timestamp, is_from_me, is_bot_message) VALUES ('${msgId}', '${KANAE_JID}', 'maintain-bot', '维护bot', '${escaped}', '${ts}', 0, 0);"`, 10000);
  if (result === null) {
    console.error('Failed to notify Kanae via DB insert');
  }
}

// ── Agent task execution (Kanae's delegated tasks) ──

function scanTasks() {
  fs.mkdirSync(TASKS_DIR, { recursive: true });
  return fs.readdirSync(TASKS_DIR).filter(f => f.endsWith('.md')).sort();
}

async function checkTasks() {
  if (busy) return;
  const files = scanTasks();
  for (const f of files) {
    if (!knownTaskFiles.has(f)) {
      knownTaskFiles.add(f);
      busy = true;
      const filePath = path.join(TASKS_DIR, f);
      const id = f.replace('.md', '');
      const startTime = Date.now();
      try {
        const content = fs.readFileSync(filePath, 'utf8');
        const title = content.split('\n')[0].replace(/^#\s*/, '');
        await notify(`⚙️ Kanae task: ${title}`);

        const context = buildContext();
        const prompt = `${context}

Kanae（维护监督者）委派了一个任务:

${content}

请认真执行这个任务。完成后：
1. 简要说明做了什么
2. 验证结果是否正确（比如检查日志、确认进程运行等）
3. 如果执行失败，说明失败原因和可能的解决方向`;

        const { output, exitCode } = await runClaude(prompt);
        const durationMs = Date.now() - startTime;

        // Write structured result to done directory
        fs.mkdirSync(TASKS_DONE_DIR, { recursive: true });
        const resultContent = `${content}

---
## 执行结果
- **状态**: ${exitCode === 0 ? '✅ 成功' : '❌ 失败'}
- **退出码**: ${exitCode}
- **耗时**: ${Math.round(durationMs / 1000)}s
- **时间**: ${new Date().toISOString()}

### 输出
${output}
`;
        fs.writeFileSync(path.join(TASKS_DONE_DIR, f), resultContent);
        fs.unlinkSync(filePath);
        knownTaskFiles.delete(f);

        const statusEmoji = exitCode === 0 ? '✅' : '⚠️';
        const statusText = exitCode === 0 ? '成功' : '失败';
        notifyKanae(f, statusText, output.slice(-500));
        await notify(`${statusEmoji} Kanae task done: ${title}\n⏱ ${Math.round(durationMs / 1000)}s\n\n${output.slice(-3000)}`);
      } catch (e) {
        const durationMs = Date.now() - startTime;
        // Still write result even on error
        try {
          fs.mkdirSync(TASKS_DONE_DIR, { recursive: true });
          const errorContent = fs.readFileSync(filePath, 'utf8') + `

---
## 执行结果
- **状态**: ❌ 异常
- **错误**: ${e.message}
- **耗时**: ${Math.round(durationMs / 1000)}s
- **时间**: ${new Date().toISOString()}
`;
          fs.writeFileSync(path.join(TASKS_DONE_DIR, f), errorContent);
          fs.unlinkSync(filePath);
        } catch { /* best effort */ }
        knownTaskFiles.delete(f);
        notifyKanae(f, '异常', e.message);
        await notify(`❌ Kanae task failed: ${id}\n${e.message}`);
      } finally {
        busy = false;
      }
      return; // one task at a time
    }
  }
  // Clean up stale entries
  for (const f of knownTaskFiles) {
    if (!files.includes(f)) knownTaskFiles.delete(f);
  }
}

// ── Telegram polling (owner DM only) ──

async function poll() {
  try {
    const url = `https://api.telegram.org/bot${BOT_TOKEN}/getUpdates?offset=${lastUpdateId + 1}&timeout=30`;
    const res = await fetch(url, { signal: AbortSignal.timeout(35000) });
    const data = await res.json();

    if (data.ok && data.result) {
      for (const update of data.result) {
        lastUpdateId = update.update_id;
        const msg = update.message;
        if (!msg?.text || msg.from?.id !== OWNER_CHAT_ID) continue;

        const text = msg.text.trim();

        if (text === '/status' || text === '/s') {
          const pid = run('pgrep -f "nanoclaw/dist/index.js"') || 'Not running';
          const containers = run('docker ps --filter "name=nanoclaw" --format "{{.Names}} — {{.Status}}" 2>/dev/null') || 'None';
          const pending = scanTasks().length;
          const portCheck = run('lsof -i :3001 -i :3002 2>/dev/null | grep LISTEN | wc -l')?.trim() || '0';
          await notify(`📊 PID: ${pid}\n📦 ${containers}\n📬 Tasks: ${pending}\n🔌 Listening ports: ${portCheck}\n🔄 Busy: ${busy}`);
        } else if (text === '/todo' || text === '/t') {
          const files = scanTasks();
          if (files.length === 0) {
            await notify('📋 No pending tasks');
          } else {
            let list = `📋 Tasks (${files.length}):\n`;
            for (const f of files) {
              const c = fs.readFileSync(path.join(TASKS_DIR, f), 'utf8');
              list += `\n⏳ ${f.replace('.md', '')}: ${c.split('\n')[0].replace(/^#\s*/, '')}`;
            }
            await notify(list);
          }
        } else {
          await handleUserMessage(text);
        }
      }
    }
  } catch (e) {
    if (e.name !== 'TimeoutError') {
      console.error('Poll error:', e.message);
      await new Promise(r => setTimeout(r, 5000));
    }
  }
}

// ── Start ──

async function start() {
  console.log('🤖 Maintenance Executor Bot starting...');
  fs.mkdirSync(TASKS_DIR, { recursive: true });
  fs.mkdirSync(TASKS_DONE_DIR, { recursive: true });

  for (const f of scanTasks()) knownTaskFiles.add(f);

  setInterval(healthCheck, HEALTH_INTERVAL);
  setInterval(checkTasks, TASK_POLL_INTERVAL);
  healthCheck();

  await notify('🤖 Maintenance executor online');

  while (true) { await poll(); }
}

start().catch(console.error);
