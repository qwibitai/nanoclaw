{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "session_start",
    "decision_log",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "blocked", "failed"]
    },
    "session_start": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "reran_after_triage",
        "background_sync_skipped"
      ],
      "properties": {
        "result": {
          "type": "string",
          "enum": ["pass", "blocked", "failed"]
        },
        "reran_after_triage": {
          "type": "boolean"
        },
        "background_sync_skipped": {
          "type": "boolean"
        }
      }
    },
    "decision_log": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_path",
        "decisions",
        "issues_created",
        "ready_issue_numbers"
      ],
      "properties": {
        "plan_path": {
          "type": ["string", "null"]
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_type",
              "source_ref",
              "decision",
              "summary"
            ],
            "properties": {
              "source_type": {
                "type": "string",
                "enum": ["discussion", "plan", "issue"]
              },
              "source_ref": {
                "type": "string"
              },
              "decision": {
                "type": "string",
                "enum": ["promote", "ready", "defer", "reject", "reference only"]
              },
              "issue_number": {
                "type": ["integer", "null"]
              },
              "summary": {
                "type": "string"
              }
            }
          }
        },
        "issues_created": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "ready_issue_numbers": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
