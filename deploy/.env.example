# NanoClaw Configuration
# =====================
# Copy this file to .env in the project root and fill in your values.
# chmod 600 .env to protect secrets.

# Required: Anthropic API key (from console.anthropic.com)
# This is separate from a Claude Max subscription - it's a pay-per-use API key.
# Estimated cost: $20-50/month depending on usage.
ANTHROPIC_API_KEY=sk-ant-XXXXX

# Assistant name (used as WhatsApp trigger: @Andy)
ASSISTANT_NAME=Andy

# Set to 'true' if the WhatsApp number is dedicated to the bot (no trigger needed)
# ASSISTANT_HAS_OWN_NUMBER=false

# --- Email Outreach (Phase 2) ---

# SMTP credentials for sending outreach emails
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=outreach@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Your Name <outreach@yourdomain.com>

# --- Social Media (Phase 4) ---

# X/Twitter API (Free tier: 1,500 posts/month, write-only)
# Get credentials at developer.twitter.com
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=

# Facebook Page (Graph API v19.0)
# Create app at developers.facebook.com, get Page Access Token
# Global (used by Messenger channel in config.ts):
# FB_PAGE_ID=
# FB_PAGE_ACCESS_TOKEN=
# Per-group overrides (used via secretOverrides in container_config):
# FB_PAGE_ID_SNAK=
# FB_PAGE_ACCESS_TOKEN_SNAK=
# FB_PAGE_ID_SHERIDAN=
# FB_PAGE_ACCESS_TOKEN_SHERIDAN=

# LinkedIn (API v2)
# Apply for API access at linkedin.com/developers
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_PERSON_URN=urn:li:person:XXXXX

# --- Google Sheets ---

# Service account key JSON (from Google Cloud Console)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Spreadsheet ID (from the Google Sheets URL)
# GOOGLE_SPREADSHEET_ID=

# --- Google Calendar ---

# Calendar ID to manage (share the calendar with the service account email)
# Format: something@group.calendar.google.com or primary
# GOOGLE_CALENDAR_ID=

# --- Quo Phone (OpenPhone) SMS Channel ---

# API key from https://app.openphone.com Settings > API
# QUO_API_KEY=

# Phone number IDs (get via API: GET /v1/phone-numbers with your API key)
# QUO_SNAK_PHONE_ID=
# QUO_SNAK_NUMBER=+16822551033

# QUO_SHERIDAN_PHONE_ID=
# QUO_SHERIDAN_NUMBER=+18175871460

# Webhook port for receiving inbound SMS (default: 3100)
# Set up webhook at https://app.openphone.com pointing to http://YOUR_VPS_IP:3100/webhook/quo
# QUO_WEBHOOK_PORT=3100

# --- Voice Transcription (Groq) ---

# Free API key from https://console.groq.com/keys
# Used for transcribing WhatsApp voice messages with Whisper
# GROQ_API_KEY=

# --- Platform Credentials (HahaVending & Vendera) ---

# HahaVending login (https://thorh5.hahabianli.com/pages/login/login)
# HAHA_EMAIL=
# HAHA_PASSWORD=

# Vendera login (https://vms.vendera.ai/login)
# VENDERA_EMAIL=
# VENDERA_PASSWORD=

# --- Optional Settings ---

# Timezone for scheduled tasks (default: system timezone)
# TZ=America/New_York

# Idle timeout in ms — how long to keep container alive after last output (default: 1800000 = 30 min)
# Reduce to 300000 (5 min) for faster container turnover
# IDLE_TIMEOUT=300000

# Container timeout in ms (default: 1800000 = 30 min)
# CONTAINER_TIMEOUT=1800000

# Max concurrent agent containers (default: 5, reduce for low-memory VPS)
# MAX_CONCURRENT_CONTAINERS=3

# Log level: trace, debug, info, warn, error
# LOG_LEVEL=info
