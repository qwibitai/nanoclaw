{
  "version": "0.2.0",
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "bash scripts/stop.sh; deno run -A src/store/index.ts & sleep 1 && deno run -A src/gateway/index.ts & deno run -A src/agent/index.ts & wait",
    "stop": "bash scripts/stop.sh",
    "gateway": "deno run -A src/gateway/index.ts",
    "agent": "deno run -A src/agent/index.ts",
    "store": "deno run -A src/store/index.ts",
    "check": "deno check src/shared/ src/gateway/ src/agent/ src/store/",
    "fmt": "deno fmt src/ skills/ knowledge/",
    "lint": "deno lint src/",
    "deploy:mgf": "bash scripts/deploy.sh foundry simt-nexus-mgf",
    "deploy:bec": "bash scripts/deploy.sh bec simt-nexus-bec"
  },
  "imports": {
    "@anthropic-ai/claude-agent-sdk": "npm:@anthropic-ai/claude-agent-sdk@^0.2.92",
    "@std/path": "jsr:@std/path@^1.0.0",
    "discord.js": "npm:discord.js@^14.18.0"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.ns", "deno.unstable", "dom"]
  },
  "exclude": [
    "node_modules/**/*",
    "dist/**/*",
    "container/**/*"
  ]
}
