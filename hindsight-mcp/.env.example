# hindsight-mcp configuration. Copy to .env and fill in the blanks.

# ── Required ──────────────────────────────────────────────────────────────
# HTTP URL of your running Hindsight engine. Examples:
#   http://localhost:3850   — engine on the same host, default port
#   http://hindsight:8888   — sibling docker service
#   http://10.x.y.z:3850    — engine on a VPN-reachable host
HINDSIGHT_URL=http://localhost:3850

# Multi-tenant Bearer tokens. Format: "token:prefix,token:prefix,...".
# Each token authenticates one client and is pinned to its bank prefix —
# clients cannot cross into another client's namespace. Generate tokens
# with e.g. `openssl rand -hex 20`.
MCP_AUTH_TOKENS=replace-with-strong-random-hex:my-namespace

# ── Optional ──────────────────────────────────────────────────────────────
# Host interface + port the wrapper publishes on. Defaults bind to loopback
# only. Use a VPN IP or 0.0.0.0 to expose externally.
# MCP_HOST_BIND=127.0.0.1
# MCP_HOST_PORT=3852
