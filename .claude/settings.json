{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/check-wip.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-pr-review.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-case-worktree.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/check-test-coverage.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/check-verification.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/check-dirty-files.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-pr-kaizen.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/warn-code-quality.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/check-practices.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/block-git-rebase.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/squash-merge-safety.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-worktree-writes.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-case-exists.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-pr-review-tools.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-pr-review-tools.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/pr-review-loop.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/kaizen-reflect-ts.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/post-merge-clear.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/pr-kaizen-clear.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/capture-worktree-context.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/post-merge-clear.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-pr-review-stop.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-post-merge-stop.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/enforce-kaizen-stop.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/verify-before-stop.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "./.claude/kaizen/hooks/check-cleanup-on-stop.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  }
}
