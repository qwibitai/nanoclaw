{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/check-wip.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/enforce-case-worktree.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/hooks/check-test-coverage.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "./.claude/hooks/check-verification.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/enforce-worktree-writes.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/review-pr-on-create.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/hooks/kaizen-reflect.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/verify-before-stop.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "./.claude/hooks/check-cleanup-on-stop.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
