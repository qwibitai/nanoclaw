#!/usr/bin/env bash
# Run a single Codex attempt. Stream JSONL to log file. Parse the final status
# code from the last message. Print just the status code (DONE/BLOCKED/etc) on stdout.
#
# Options:
#   --worktree <dir>        working root for codex
#   --log <file>            JSONL output log
#   --prompt-file <file>    rendered prompt (plain text)
#   --reasoning <lvl>       low|medium|high|xhigh
#   --session-file <file>   path; if exists, we resume the session id written
#                           there; in any case we write the new session id
#                           (or a synthesized one if codex didn't expose it).
#   --timeout <sec>         optional, default 1800
set -euo pipefail

CODEX="${CODEX_BIN:-codex}"

WT=""; LOG=""; PROMPT_FILE=""; REASONING="high"; SID_FILE=""; TO=1800
while [ $# -gt 0 ]; do
  case "$1" in
    --worktree)     WT="$2"; shift 2 ;;
    --log)          LOG="$2"; shift 2 ;;
    --prompt-file)  PROMPT_FILE="$2"; shift 2 ;;
    --reasoning)    REASONING="$2"; shift 2 ;;
    --session-file) SID_FILE="$2"; shift 2 ;;
    --timeout)      TO="$2"; shift 2 ;;
    *) echo "unknown flag: $1" >&2; exit 2 ;;
  esac
done
: "${WT:?--worktree required}"
: "${LOG:?--log required}"
: "${PROMPT_FILE:?--prompt-file required}"
: "${SID_FILE:?--session-file required}"

prompt="$(cat "$PROMPT_FILE")"

mkdir -p "$(dirname "$LOG")"

args=(exec
  -s workspace-write
  -C "$WT"
  -c "model_reasoning_effort=\"$REASONING\""
  --enable web_search_cached
  --json)

if [ -s "$SID_FILE" ]; then
  args=(exec resume "$(cat "$SID_FILE")"
    -C "$WT"
    -c "model_reasoning_effort=\"$REASONING\""
    --enable web_search_cached
    --json)
fi

if command -v timeout >/dev/null 2>&1; then
  TO_CMD=(timeout "$TO")
elif command -v gtimeout >/dev/null 2>&1; then
  TO_CMD=(gtimeout "$TO")
else
  TO_CMD=()
fi

tmp_out="$(mktemp)"
trap 'rm -f "$tmp_out"' EXIT

set +e
"${TO_CMD[@]+"${TO_CMD[@]}"}" "$CODEX" "${args[@]}" "$prompt" > "$tmp_out" 2>&1
rc=$?
set -e

cat "$tmp_out" >> "$LOG"

# jq may return non-zero on non-JSON output (e.g. test stubs that just echo
# "DONE"). Under set -euo pipefail this would abort the script; tolerate it.
{ jq -r 'select(.session_id != null) | .session_id' "$tmp_out" 2>/dev/null || true; } \
  | tail -n1 > "$SID_FILE.new" || true
if [ -s "$SID_FILE.new" ]; then mv "$SID_FILE.new" "$SID_FILE"; else rm -f "$SID_FILE.new"; fi

final_text="$({ jq -r 'select(.text != null) | .text' "$tmp_out" 2>/dev/null || true; } | tail -n1)"
if [ -z "$final_text" ]; then
  final_text="$(tail -n 5 "$tmp_out")"
fi

case "$final_text" in
  *DONE_WITH_CONCERNS*) status="DONE_WITH_CONCERNS" ;;
  *DONE*)                status="DONE" ;;
  *NEEDS_CONTEXT*)       status="NEEDS_CONTEXT" ;;
  *BLOCKED*)             status="BLOCKED" ;;
  *)
    if [ "$rc" -eq 124 ]; then
      status="BLOCKED"
    elif [ "$rc" -ne 0 ]; then
      status="BLOCKED"
    else
      status="DONE_WITH_CONCERNS"
    fi
    ;;
esac

# Auto-commit codex's changes. codex exec -s workspace-write cannot write to
# the parent repo's .git/worktrees/<name>/ (git-worktree metadata lives
# outside the codex sandbox), so git commits from inside the model fail
# silently. Bash runs outside the sandbox, so we commit here on its behalf
# whenever codex thinks it finished the work. Skip on BLOCKED/NEEDS_CONTEXT
# (the wave will retry or escalate; half-done work should not be squashed).
if [ "$status" = "DONE" ] || [ "$status" = "DONE_WITH_CONCERNS" ]; then
  if (cd "$WT" && [ -n "$(git status --porcelain 2>/dev/null)" ]); then
    (cd "$WT" \
      && git -c user.email=codex@local -c user.name=codex add -A \
      && git -c user.email=codex@local -c user.name=codex commit -qm \
        "codex task: auto-commit of worktree changes") || true
  fi
fi

echo "$status"
exit 0
