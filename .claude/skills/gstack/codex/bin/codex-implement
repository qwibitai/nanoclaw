#!/usr/bin/env bash
# /codex implement entry point. Orchestrates parse → per-wave run → per-wave merge.
#
# Usage:
#   codex-implement <plan-file> [options]
#
# Options:
#   --base <ref>          default: local main/master. Must be a LOCAL branch,
#                         not a remote-tracking ref like origin/main.
#   --dry-run             parse-only, print summary, exit 0
#   --resume              resume from state.json
#   --rollback            revert every merged commit (see --rollback doc)
#   --only-task N         limit to a single task (for canary runs)
#   --max-parallel N      fan-out ceiling, default 4
#   --task-timeout SEC    default 1800
#   --force               bypass plan-sha mismatch on --resume
#   --force-clean         also clean orphan worktrees before starting
set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BIN="$SKILL_DIR/bin"

GSTACK_HOME="${GSTACK_HOME:-$HOME/.gstack}"
WORK_ROOT="$GSTACK_HOME/codex-work"
mkdir -p "$WORK_ROOT"

PLAN=""
BASE=""; BASE_EXPLICIT=0; DRY=0; RESUME=0; ROLLBACK=0; ONLY_TASK=""
MAX_PAR=4; TO=1800; FORCE=0; FORCE_CLEAN=0

while [ $# -gt 0 ]; do
  case "$1" in
    --base)         BASE="$2"; BASE_EXPLICIT=1; shift 2 ;;
    --dry-run)      DRY=1; shift ;;
    --resume)       RESUME=1; shift ;;
    --rollback)     ROLLBACK=1; shift ;;
    --only-task)    ONLY_TASK="$2"; shift 2 ;;
    --max-parallel) MAX_PAR="$2"; shift 2 ;;
    --task-timeout) TO="$2"; shift 2 ;;
    --force)        FORCE=1; shift ;;
    --force-clean)  FORCE_CLEAN=1; shift ;;
    -*) echo "unknown flag: $1" >&2; exit 2 ;;
    *)  PLAN="$1"; shift ;;
  esac
done
[ -r "$PLAN" ] || { echo "usage: codex-implement <plan-file> [...]" >&2; exit 2; }

# Namespace the work dir by repo + plan path so two plans named plan.md in
# different repos (or two plans named plan.md at different paths inside the
# same repo) don't collide at ~/.gstack/codex-work/plan and corrupt each
# other's lock / state.json / markers / sub-worktrees.
_plan_base="$(basename "$PLAN" .md)"
_plan_path_abs="$(cd "$(dirname "$PLAN")" && pwd)/$(basename "$PLAN")"
_repo_id="$(git rev-parse --show-toplevel 2>/dev/null | xargs -I{} basename {} 2>/dev/null || echo no-repo)"
_path_hash="$(printf '%s' "$_plan_path_abs" | shasum -a 1 2>/dev/null | cut -c1-8)"
plan_slug="${_repo_id}--${_plan_base}--${_path_hash}"
WORK="$WORK_ROOT/$plan_slug"
mkdir -p "$WORK"

preflight() {
  if [ "$DRY" -eq 0 ] && [ "$ROLLBACK" -eq 0 ]; then
    if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
      echo "ERROR: working tree is not clean. Commit or stash before running." >&2
      exit 2
    fi
    if ! command -v "${CODEX_BIN:-codex}" >/dev/null 2>&1; then
      echo "ERROR: codex CLI not found on PATH" >&2; exit 2
    fi
    if ! git worktree list >/dev/null 2>&1; then
      echo "ERROR: git worktree is not available (need Git >= 2.5)" >&2; exit 2
    fi
  fi
}

# Run preflight BEFORE parsing/locking so dirty-tree errors surface fastest.
preflight

LOCK="$WORK/lock"
PIDFILE="$WORK/lock.pid"
if command -v flock >/dev/null 2>&1; then
  exec 9>"$LOCK"
  if ! flock -n 9; then
    echo "ERROR: another /codex implement run is active on this plan." >&2
    exit 2
  fi
else
  # macOS and other systems without flock: fall back to a PID file with a
  # liveness check. Two concurrent /codex implement runs against the same
  # plan would otherwise race on $WORK (state.json, markers, sub-worktrees)
  # and corrupt each other.
  if [ -r "$PIDFILE" ]; then
    old_pid="$(cat "$PIDFILE" 2>/dev/null || echo "")"
    if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
      echo "ERROR: another /codex implement run (pid $old_pid) is active on this plan." >&2
      exit 2
    fi
    # stale pid file
    rm -f "$PIDFILE"
  fi
  echo "$$" > "$PIDFILE"
  trap 'rm -f "$PIDFILE"' EXIT
fi

PLAN_JSON="$WORK/plan.json"
# Rollback should work even if the plan now fails to parse (e.g. a task was
# renamed into a duplicate slug after the original run). Rollback only needs
# state.json, which has the recorded task nums/slugs/commits. Skip re-parsing
# in that case and reuse whatever plan.json the original run wrote.
if [ "$ROLLBACK" -eq 1 ] && [ -r "$PLAN_JSON" ]; then
  : # use the cached plan.json as-is
else
  "$BIN/codex-parse-plan" "$PLAN" > "$PLAN_JSON"
fi

# Even when --base was provided explicitly, reject remote-tracking refs.
# codex-merge-wave checks them out and commits into them, but a remote ref
# leaves git on detached HEAD and every squash commit becomes an orphan as
# soon as the user switches branches. Refuse upfront with a helpful error.
if [ -n "$BASE" ] && git show-ref --verify --quiet "refs/remotes/$BASE"; then
  if ! git show-ref --verify --quiet "refs/heads/$BASE"; then
    echo "ERROR: --base $BASE is a remote-tracking ref." >&2
    echo "       codex-merge-wave would commit onto a detached HEAD and" >&2
    echo "       orphan every squash commit. Create a local branch first:" >&2
    _local_name="${BASE#origin/}"
    echo "         git checkout -b $_local_name $BASE" >&2
    echo "       Then pass --base $_local_name." >&2
    exit 2
  fi
fi

if [ -z "$BASE" ]; then
  # Require a LOCAL branch as the base. codex-merge-wave does
  # `git checkout -q "$BASE"` and commits into it; a remote-tracking ref
  # like origin/main checks out in detached HEAD and the squash commits
  # never advance any named branch. In that case switching branches at
  # the end of the run would orphan every merged commit. Fail loudly
  # rather than silently lose work.
  if git show-ref --verify --quiet refs/heads/main; then
    BASE="main"
  elif git show-ref --verify --quiet refs/heads/master; then
    BASE="master"
  else
    echo "ERROR: no local main or master branch found." >&2
    if git show-ref --verify --quiet refs/remotes/origin/main; then
      echo "       origin/main exists but is a remote ref — checking it out" >&2
      echo "       would put every merge on a detached HEAD and orphan the" >&2
      echo "       commits. Create a local tracking branch first:" >&2
      echo "         git checkout -b main origin/main" >&2
      echo "       Or pass --base <local-branch> explicitly." >&2
    else
      echo "       Pass --base <local-branch> explicitly." >&2
    fi
    exit 2
  fi
fi

if [ "$DRY" -eq 1 ]; then
  waves="$(jq '.waves | length' "$PLAN_JSON")"
  tasks="$(jq '.tasks | length' "$PLAN_JSON")"
  printf 'plan: %s\ntasks: %d\nwaves: %d\nbase: %s\n' "$PLAN" "$tasks" "$waves" "$BASE"
  jq -r '.waves[] | "Wave \(.wave): \(.tasks | length) task(s) — " + (.tasks | map(tostring) | join(", "))' "$PLAN_JSON"
  exit 0
fi

if [ "$ROLLBACK" -eq 1 ]; then
  STATE="$WORK/state.json"
  [ -r "$STATE" ] || { echo "nothing to roll back"; exit 0; }
  # If --base wasn't explicitly provided for this invocation, use whichever
  # base_ref the original run recorded. Otherwise a plan run against
  # `release/v2` would get reverted on top of today's default `main`.
  if [ "$BASE_EXPLICIT" -eq 0 ]; then
    recorded_base="$(jq -r '.base_ref // empty' "$STATE")"
    if [ -n "$recorded_base" ]; then
      BASE="$recorded_base"
    fi
  fi
  shas="$(jq -r '.waves[].tasks[] | select(.final_commit_on_base != null) | .final_commit_on_base' "$STATE" \
          | awk '{a[NR]=$0} END{for(i=NR;i>=1;i--) print a[i]}')"
  git checkout -q "$BASE"
  for s in $shas; do
    git revert --no-edit "$s"
  done
  # Tear down any sub-worktrees that were preserved by the deferred-teardown
  # policy, then delete their task branches. Without this, a subsequent run
  # of the same plan would fail in codex-worktree setup with
  # "fatal: a branch named codex/<plan>/<slug> already exists".
  # Use slugs from state.json (the recorded run) rather than the current
  # plan.json, in case the plan was edited after the run (task renames would
  # otherwise leave the original branches behind).
  rollback_slugs="$(jq -r '.waves[].tasks[].slug // empty' "$STATE" 2>/dev/null)"
  if [ -z "$rollback_slugs" ]; then
    rollback_slugs="$(jq -r '.tasks[].slug' "$PLAN_JSON" 2>/dev/null)"
  fi
  for sl in $rollback_slugs; do
    [ -z "$sl" ] && continue
    if [ -d "$WORK/$sl" ]; then
      "$BIN/codex-worktree" teardown "$WORK" "$sl" > /dev/null 2>&1 || true
    fi
  done
  # Prune stale linked-worktree metadata so branch -D can delete branches
  # whose worktree was removed out-of-band before this rollback runs.
  git worktree prune > /dev/null 2>&1 || true
  for sl in $rollback_slugs; do
    [ -z "$sl" ] && continue
    if git show-ref --verify --quiet "refs/heads/codex/$plan_slug/$sl"; then
      git branch -D "codex/$plan_slug/$sl" > /dev/null 2>&1 || true
    fi
  done
  rm -rf "$WORK"
  echo "rollback complete; state dir removed"
  exit 0
fi

STATE="$WORK/state.json"
if [ "$RESUME" -eq 1 ]; then
  [ -r "$STATE" ] || { echo "ERROR: --resume but no state.json"; exit 2; }
  recorded_sha="$(jq -r '.plan_sha' "$STATE")"
  current_sha="$(shasum -a 256 "$PLAN" | cut -d' ' -f1)"
  if [ "$FORCE" -eq 0 ] && [ "$recorded_sha" != "$current_sha" ]; then
    echo "ERROR: plan was edited since run started (use --force to override)" >&2
    exit 2
  fi
else
  [ -e "$STATE" ] && { echo "ERROR: state.json exists. Use --resume or --force-clean."; exit 2; }
  plan_sha="$(shasum -a 256 "$PLAN" | cut -d' ' -f1)"
  base_sha="$(git rev-parse "$BASE")"
  waves_arr="$(jq '.waves' "$PLAN_JSON")"
  tasks_arr="$(jq '.tasks | map({num, slug})' "$PLAN_JSON")"
  "$BIN/codex-state" init "$WORK" \
    --plan-path "$PLAN" --plan-sha "$plan_sha" \
    --base-ref "$BASE"  --base-sha "$base_sha" \
    --waves "$waves_arr" --tasks "$tasks_arr"
fi

if [ "$FORCE_CLEAN" -eq 1 ]; then
  for s in $(jq -r '.tasks[].slug' "$PLAN_JSON"); do
    "$BIN/codex-worktree" teardown "$WORK" "$s" > /dev/null || true
  done
fi

# Resolve --only-task: if set, find which wave the task lives in and skip all
# other waves entirely. This makes the canary path actually canary — a single
# task runs, gets gated, gets merged; unrelated tasks from other waves stay
# untouched.
only_wave=""
if [ -n "$ONLY_TASK" ]; then
  only_wave="$(jq -r --argjson n "$ONLY_TASK" \
    '.waves[] | select(.tasks | index($n)) | .wave' "$PLAN_JSON" 2>/dev/null | head -1)"
  if [ -z "$only_wave" ] || [ "$only_wave" = "null" ]; then
    echo "ERROR: --only-task $ONLY_TASK does not match any task in the plan" >&2
    exit 2
  fi
  echo "only-task mode: running task $ONLY_TASK in wave $only_wave; all other waves skipped"
fi

total_waves="$(jq '.waves | length' "$PLAN_JSON")"
# Iterate the declared wave numbers (in declaration order) instead of
# 1..length. Plans can use non-contiguous labels like Wave 1 and Wave 3,
# and `seq 1 total_waves` would silently skip the later one.
wave_nums="$(jq -r '.waves[].wave' "$PLAN_JSON")"
for wave in $wave_nums; do
  if [ -n "$only_wave" ] && [ "$wave" != "$only_wave" ]; then
    continue
  fi
  wstate="$(jq -r --argjson w "$wave" '.waves[] | select(.wave == $w) | .status' "$STATE")"
  if [ "$wstate" = "completed" ]; then
    echo "[WAVE $wave/$total_waves] skipped (already completed)"
    continue
  fi
  "$BIN/codex-state" set-wave-status "$WORK" --wave "$wave" --status in_progress
  echo "[WAVE $wave/$total_waves] starting"

  only_task_args=()
  if [ -n "$ONLY_TASK" ]; then only_task_args=(--only-task "$ONLY_TASK"); fi

  if ! "$BIN/codex-run-wave" \
        --work-dir "$WORK" --wave "$wave" --base "$BASE" \
        --plan-json "$PLAN_JSON" --max-parallel "$MAX_PAR" \
        --task-timeout "$TO" "${only_task_args[@]+"${only_task_args[@]}"}"; then
    echo "[WAVE $wave] escalated; state checkpointed at $STATE"
    exit 2
  fi

  if ! "$BIN/codex-merge-wave" \
        --work-dir "$WORK" --wave "$wave" --base "$BASE" \
        --plan-json "$PLAN_JSON" "${only_task_args[@]+"${only_task_args[@]}"}"; then
    echo "[WAVE $wave] merge or post-wave test failed; state checkpointed"
    exit 2
  fi
done

echo "all waves complete. merged commits on $BASE:"
jq -r '.waves[].tasks[] | select(.final_commit_on_base != null) | "  \(.num) \(.slug) → \(.final_commit_on_base[0:8])"' "$STATE"
