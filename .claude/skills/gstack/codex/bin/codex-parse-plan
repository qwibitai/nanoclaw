#!/usr/bin/env bash
# Parse a superpowers-format implementation plan.
# Emits a JSON object on stdout describing goal, architecture, test_command,
# tasks (with slug + files + body), and waves.
# Hard-errors (exit 2) on: duplicate task ref, missing task ref, overlapping
# file claims within a wave, malformed task heading.
# Soft-warns (stderr) + serial fallback when ## Parallelization is missing.
set -euo pipefail

if [ $# -lt 1 ] || [ ! -r "$1" ]; then
  echo "usage: codex-parse-plan <plan.md>" >&2
  exit 2
fi
PLAN="$1"

# Delegate all parsing + validation to a single Python3 invocation.
# Python script is written to a temp file to avoid heredoc-in-subshell issues.
_PY_SCRIPT="$(mktemp /tmp/codex-parse-plan.XXXXXX.py)"
trap 'rm -f "$_PY_SCRIPT"' EXIT

cat > "$_PY_SCRIPT" << 'PYEOF'
#!/usr/bin/env python3
"""
Parse a superpowers-format implementation plan and emit JSON.
Exit 2 on hard errors; print WARNING to stderr for soft issues.
"""
import sys
import json
import re

plan_file = sys.argv[1]
with open(plan_file) as f:
    original_content = f.read()

# Strip fenced code blocks (``` ... ```) for HEADING/PARALLELIZATION
# DETECTION only — a plan that shows `### Task 99: example` inside a code
# fence would otherwise be mis-parsed as a real task. Task BODIES are
# extracted from the original content so fenced examples (SQL, JSON, shell
# commands, etc.) land intact in plan.json and the implementer prompt /
# Stage-3 spec check see the full instructions.
def _strip_fences(text):
    out = []
    in_fence = False
    for line in text.split("\n"):
        if line.lstrip().startswith("```"):
            in_fence = not in_fence
            out.append("")
            continue
        out.append("" if in_fence else line)
    return "\n".join(out)

content = _strip_fences(original_content)

def extract_header(label):
    """Extract the value from a **Label:** line (case-insensitive).
    Strips surrounding backticks from inline code spans."""
    pattern = re.compile(
        r'^\*\*' + re.escape(label) + r':\*\*\s*(.+)$',
        re.MULTILINE | re.IGNORECASE
    )
    m = pattern.search(content)
    if not m:
        return ""
    val = m.group(1).strip()
    # strip surrounding backticks: `value` -> value
    if val.startswith('`') and val.endswith('`') and len(val) >= 2:
        val = val[1:-1]
    return val

goal = extract_header("Goal")
architecture = extract_header("Architecture")
test_command = extract_header("Test command")

# ---- extract tasks ----
task_header_re = re.compile(r'^### Task (\d+):\s*(.*?)$', re.MULTILINE)
task_matches = list(task_header_re.finditer(content))

def slugify(s):
    s = s.lower()
    s = re.sub(r'[^a-z0-9]+', '-', s)
    return s.strip('-')

file_re = re.compile(
    r'^[-*]\s+(?:Create|Modify|Test):\s+`?([^`\s\n]+)`?',
    re.IGNORECASE | re.MULTILINE
)

tasks = []
# Offsets from task_matches are into the fence-STRIPPED `content`. But we
# want task BODIES sliced from the fence-PRESERVED `original_content` so
# fenced examples survive into plan.json. Since _strip_fences preserves
# line count (fence lines → blank lines), we can map match-line-numbers
# back to the same lines in the original.
stripped_lines = content.split("\n")
original_lines = original_content.split("\n")
for i, m in enumerate(task_matches):
    num = int(m.group(1))
    heading = m.group(2).strip()
    # Find the heading's line number in the stripped content.
    heading_line = content.count("\n", 0, m.start())
    next_heading_line = (
        content.count("\n", 0, task_matches[i + 1].start())
        if i + 1 < len(task_matches)
        else len(original_lines)
    )
    # Body is everything AFTER the heading line up to (not including) the
    # next heading line, extracted from the ORIGINAL content so fenced
    # blocks survive into the implementer prompt / Stage-3 spec check.
    body = "\n".join(original_lines[heading_line + 1:next_heading_line])
    if body and not body.endswith("\n"):
        body += "\n"
    # Metadata extraction (file claims, Run: gate) must NOT pick up
    # fenced examples: a task that shows `Run: rm -rf /` inside a code
    # fence should not set that as the real gate. Use a fence-stripped
    # view for regex scans while keeping the original for `body`.
    body_for_meta = "\n".join(stripped_lines[heading_line + 1:next_heading_line])

    files = file_re.findall(body_for_meta)
    run_matches = re.findall(r'(?m)^Run:\s+`?([^`\n]+)`?\s*$', body_for_meta)
    task_test_cmd = run_matches[-1].strip() if run_matches else None

    tasks.append({
        "num": num,
        "heading": heading,
        "slug": slugify(heading),
        "files": files,
        "test_command": task_test_cmd,
        "body": body,
    })

# ---- parse Parallelization section ----
para_re = re.compile(
    r'^## Parallelization\s*$(.*?)(?=^## |\Z)',
    re.MULTILINE | re.DOTALL
)
para_match = para_re.search(content)

waves = []
if para_match:
    wave_line_re = re.compile(
        r'^-\s+Wave\s+(\d+):\s*Tasks?\s+(.+)$',
        re.IGNORECASE
    )
    for line in para_match.group(1).splitlines():
        wm = wave_line_re.match(line.strip())
        if wm:
            wave_num = int(wm.group(1))
            task_nums = [int(x) for x in re.findall(r'\d+', wm.group(2))]
            waves.append({"wave": wave_num, "tasks": task_nums})

if not waves:
    print(
        "WARNING: plan has no ## Parallelization section; running fully serial",
        file=sys.stderr
    )
    nums = sorted(t['num'] for t in tasks)
    waves = [{"wave": i + 1, "tasks": [n]} for i, n in enumerate(nums)]

# ---- validation ----
errors = []

# duplicate refs
all_refs = [n for w in waves for n in w['tasks']]
seen = set()
dups = []
for n in all_refs:
    if n in seen and n not in dups:
        dups.append(n)
    seen.add(n)
if dups:
    errors.append(f"ERROR: duplicate task references in Parallelization: {' '.join(str(d) for d in dups)}")

declared = {t['num'] for t in tasks}
referenced = set(all_refs)

missing = sorted(declared - referenced)
if missing:
    errors.append(f"ERROR: tasks declared but not referenced in Parallelization: {' '.join(str(n) for n in missing)}")

extra = sorted(referenced - declared)
if extra:
    errors.append(f"ERROR: Parallelization references unknown task numbers: {' '.join(str(n) for n in extra)}")

# Reject duplicate task numbers before collapsing to a dict. A dict
# comprehension would silently drop earlier definitions and run the wrong
# body/files for the affected task number, with no error.
seen_nums = set()
dup_nums = []
for t in tasks:
    if t['num'] in seen_nums:
        if t['num'] not in dup_nums:
            dup_nums.append(t['num'])
    else:
        seen_nums.add(t['num'])
if dup_nums:
    errors.append(f"ERROR: duplicate task numbers: {' '.join(str(n) for n in dup_nums)}")

# Reject duplicate slugs. Slugs are derived from task headings; two tasks
# with the same heading (e.g. "Task 1: apply fix" in Wave 1 and "Task 7:
# apply fix" in Wave 3) would both resolve to the same slug and therefore
# the same worktree directory + branch name. With deferred teardown across
# waves, the second wave's codex-worktree setup would fail with
# "already exists".
seen_slugs = {}
dup_slugs = set()
for t in tasks:
    if t['slug'] in seen_slugs:
        dup_slugs.add(t['slug'])
    else:
        seen_slugs[t['slug']] = t['num']
if dup_slugs:
    errors.append(
        "ERROR: duplicate task slugs (derived from headings). Rename a task "
        f"so slugs are unique across the plan: {' '.join(sorted(dup_slugs))}"
    )

# Require a real Stage-1 gate for every task:
#   * Multi-task plans: every task MUST declare its own `Run:` line.
#     The plan-level `**Test command:**` is the post-wave acceptance
#     test; it typically depends on artifacts from peer tasks that
#     aren't yet merged during an isolated task worktree's Stage-1,
#     and substituting `true` would let broken commits land on BASE
#     before the post-wave test runs.
#   * Single-task plans: the task's own `Run:` line OR the plan-level
#     `**Test command:**` is sufficient (they're equivalent for a
#     one-task plan).
if len(tasks) > 1:
    tasks_without_run = [t['num'] for t in tasks if not t.get('test_command')]
    if tasks_without_run:
        errors.append(
            "ERROR: multi-task plans require every task to declare its own "
            "`Run:` line. The plan-level **Test command:** is the post-wave "
            "acceptance test and is not a valid substitute for per-task "
            "Stage-1 gates (it typically needs artifacts from peer tasks "
            "that aren't merged yet). "
            f"Tasks missing Run:: {' '.join(str(n) for n in tasks_without_run)}"
        )
else:
    # Single-task: either source is fine.
    if not test_command and not any(t.get('test_command') for t in tasks):
        errors.append(
            "ERROR: single-task plans must declare either a `Run:` line on "
            "the task or a plan-level **Test command:** header (the task "
            "would otherwise be squash-merged with zero runnable "
            "verification)."
        )

# overlapping files within a wave
task_map = {t['num']: t for t in tasks}
for w in waves:
    wave_tasks = [task_map[n] for n in w['tasks'] if n in task_map]
    for i in range(len(wave_tasks)):
        for j in range(i + 1, len(wave_tasks)):
            ti = wave_tasks[i]
            tj = wave_tasks[j]
            shared = sorted(set(ti['files']) & set(tj['files']))
            if shared:
                errors.append(
                    f"ERROR: overlapping file claims within wave:\n"
                    f"  wave={w['wave']} task={ti['num']} task={tj['num']} "
                    f"files={','.join(shared)}"
                )

if errors:
    for e in errors:
        print(e, file=sys.stderr)
    sys.exit(2)

# ---- emit JSON ----
print(json.dumps({
    "goal": goal,
    "architecture": architecture,
    "test_command": test_command,
    "tasks": tasks,
    "waves": waves,
}, indent=2))
PYEOF

python3 "$_PY_SCRIPT" "$PLAN"
