#!/usr/bin/env bash
# Run ONE wave of tasks:
#   1. for each task in the wave, set up worktree and dispatch codex (up to max-parallel)
#   2. run the 3-stage gate per task; on gate failure, re-dispatch (retry ladder)
#   3. tasks that pass → leave the worktree + branch in place for the merger
#   4. tasks that exhaust retries → emit needs-claude-fallback marker;
#      wait for claude-fallback-result; if still bad, state=escalated and stop wave
#
# Flags:
#   --work-dir <dir>     plan work dir
#   --wave <N>           wave number
#   --base <ref>
#   --plan-json <file>   output of codex-parse-plan
#   --max-parallel <N>   default 4
#   --task-timeout <sec> default 1800
#
# Exits 0 if every task in the wave ends up "passed gate".
# Exits 2 if any task ended up "escalated".
#
# Portability: bash 3.2 compatible (no declare -A, no wait -n).
set -euo pipefail

WORK="" WAVE="" BASE="" PLAN_JSON="" MAX_PARALLEL=4 TIMEOUT=1800 ONLY_TASK=""
while [ $# -gt 0 ]; do
  case "$1" in
    --work-dir)      WORK="$2"; shift 2 ;;
    --wave)          WAVE="$2"; shift 2 ;;
    --base)          BASE="$2"; shift 2 ;;
    --plan-json)     PLAN_JSON="$2"; shift 2 ;;
    --max-parallel)  MAX_PARALLEL="$2"; shift 2 ;;
    --task-timeout)  TIMEOUT="$2"; shift 2 ;;
    --only-task)     ONLY_TASK="$2"; shift 2 ;;
    *) echo "unknown flag: $1" >&2; exit 2 ;;
  esac
done
: "${WORK:?}" "${WAVE:?}" "${BASE:?}" "${PLAN_JSON:?}"

SKILL_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BIN="$SKILL_DIR/bin"
PROMPT_TMPL="$SKILL_DIR/codex-implementer-prompt.md"

# tasks in this wave (newline-separated numbers)
wave_tasks="$(jq -r --argjson w "$WAVE" \
  '.waves[] | select(.wave == $w) | .tasks[]' "$PLAN_JSON")"

# With --only-task, narrow the wave down to a single task. Other tasks in
# the same wave are not dispatched this run.
if [ -n "$ONLY_TASK" ]; then
  filtered=""
  for t in $wave_tasks; do
    if [ "$t" = "$ONLY_TASK" ]; then filtered="$t"; fi
  done
  wave_tasks="$filtered"
fi

task_meta() {  # $1 = task num; emits json
  jq --argjson n "$1" '.tasks[] | select(.num == $n)' "$PLAN_JSON"
}

# Fallback marker filenames include a generation suffix (pid + epoch)
# so a delayed reply from a prior --force-clean'd run's fallback worker
# cannot be consumed by a restarted attempt. The suffix is written into
# both the request (needs-claude-fallback.<W>.<N>.<gen>.json) and the
# matching reply (claude-fallback-result.<W>.<N>.<gen>.json). Workers
# that poll for needs-claude-fallback.*.json and substitute
# 'needs-claude-fallback' → 'claude-fallback-result' will still produce
# the correct reply path.
fb_gen_new() { echo "$$-$(date +%s)"; }

render_prompt() {
  local num="$1" findings="${2:-}" forbidden="$3"
  local meta heading body test_cmd slug goal arch prior_section=""
  meta="$(task_meta "$num")"
  heading="$(jq -r '.heading' <<<"$meta")"
  body="$(jq -r '.body' <<<"$meta")"
  slug="$(jq -r '.slug' <<<"$meta")"
  test_cmd="$(jq -r '.test_command // empty' <<<"$meta")"
  # Plan-size-aware fallback (matches process_one's stage-1 logic):
  # multi-task plans fall back to `true` so we don't tell codex to run the
  # whole-plan acceptance command inside an isolated task worktree; only
  # single-task plans fall back to the plan-level test.
  if [ -z "$test_cmd" ]; then
    plan_total_tasks="$(jq '.tasks | length' "$PLAN_JSON")"
    if [ "$plan_total_tasks" = "1" ]; then
      test_cmd="$(jq -r '.test_command // "true"' "$PLAN_JSON")"
      [ -z "$test_cmd" ] || [ "$test_cmd" = "null" ] && test_cmd="true"
    else
      test_cmd="true"
    fi
  fi
  goal="$(jq -r '.goal' "$PLAN_JSON")"
  arch="$(jq -r '.architecture' "$PLAN_JSON")"

  if [ -n "$findings" ] && [ -r "$findings" ]; then
    prior_section="PRIOR ATTEMPT FAILED BECAUSE:
$(cat "$findings")

Fix and re-verify."
  fi

  # awk -v can't take multi-line values; ship via env + ENVIRON[] instead.
  # awk gsub() interprets `&` in the replacement string as "the matched text",
  # so values containing `&` (e.g. a test command with `&&`) would corrupt the
  # output by re-inserting the placeholder. Pre-escape `&` -> `\&` so it lands
  # literally. Note: we do NOT also escape `\`. BSD awk (macOS default) and
  # GNU awk handle unescaped `\` differently in replacement strings, and
  # over-escaping (which works on GNU awk) produces quadrupled backslashes
  # on BSD awk. Task bodies and test commands rarely contain literal `\`.
  RP_GOAL="$goal" RP_ARCH="$arch" RP_HEADING="$heading" \
    RP_BODY="$body" RP_PRIOR="$prior_section" \
    RP_WT="$WORK/$slug" RP_FB="$forbidden" RP_TC="$test_cmd" \
    awk '
      function esc(s) {
        gsub(/&/, "\\\\&", s)
        return s
      }
      BEGIN {
        e_goal = esc(ENVIRON["RP_GOAL"])
        e_arch = esc(ENVIRON["RP_ARCH"])
        e_head = esc(ENVIRON["RP_HEADING"])
        e_body = esc(ENVIRON["RP_BODY"])
        e_prior= esc(ENVIRON["RP_PRIOR"])
        e_wt   = esc(ENVIRON["RP_WT"])
        e_fb   = esc(ENVIRON["RP_FB"])
        e_tc   = esc(ENVIRON["RP_TC"])
      }
      {
        gsub(/\{\{GOAL\}\}/,                   e_goal)
        gsub(/\{\{ARCHITECTURE\}\}/,           e_arch)
        gsub(/\{\{TASK_HEADING\}\}/,           e_head)
        gsub(/\{\{TASK_BODY\}\}/,              e_body)
        gsub(/\{\{PRIOR_ATTEMPT_FINDINGS\}\}/, e_prior)
        gsub(/\{\{WORKTREE_PATH\}\}/,          e_wt)
        gsub(/\{\{FORBIDDEN_FILES\}\}/,        e_fb)
        gsub(/\{\{TEST_COMMAND\}\}/,           e_tc)
        print
      }
    ' "$PROMPT_TMPL"
}

# Precompute and cache each task's forbidden-files list in $WORK/forbidden.<n>
# (bash 3.2 has no associative arrays; files serve as the same lookup.)
mkdir -p "$WORK"
for n in $wave_tasks; do
  others="$(jq -r --argjson n "$n" --argjson w "$WAVE" '
    [.waves[] | select(.wave == $w) | .tasks[] | select(. != $n)] as $peers
    | .tasks[] | select(.num | IN($peers[])) | .files[]' "$PLAN_JSON" \
    | sort -u | paste -sd, -)"
  printf '%s' "$others" > "$WORK/forbidden.$n"
done

LOGS="$WORK/logs"; mkdir -p "$LOGS"

process_one() {
  local num="$1"
  local slug wt sid_file prompt_file attempt reasoning test_cmd forbidden
  slug="$(task_meta "$num" | jq -r '.slug')"
  wt="$WORK/$slug"
  sid_file="$WORK/sid.$WAVE.$num"
  prompt_file="$WORK/prompt.$WAVE.$num.txt"
  attempt=1
  reasoning="high"
  test_cmd="$(task_meta "$num" | jq -r '.test_command // empty')"
  # Per-task stage-1 test fallback:
  # * Multi-task plans: fall back to `true` (no-op). The plan-level test is a
  #   whole-plan acceptance test that typically can't hold in an isolated task
  #   worktree (a task can't see its peers' artifacts yet).
  # * Single-task plans: fall back to the plan-level test. There's no peer
  #   scope to worry about, and bypassing the check here would let a broken
  #   commit land on BASE before the plan test fired.
  if [ -z "$test_cmd" ]; then
    plan_total_tasks="$(jq '.tasks | length' "$PLAN_JSON")"
    if [ "$plan_total_tasks" = "1" ]; then
      test_cmd="$(jq -r '.test_command // "true"' "$PLAN_JSON")"
      [ -z "$test_cmd" ] || [ "$test_cmd" = "null" ] && test_cmd="true"
    else
      test_cmd="true"
    fi
  fi
  forbidden="$(cat "$WORK/forbidden.$num" 2>/dev/null || printf '')"
  local findings=""

  # Read the prior status BEFORE we overwrite it with `dispatched`. This
  # distinguishes three resume cases:
  #   * claude-fallback: the previous run handed off to a Claude subagent.
  #     Preserve the worktree + fallback markers — those contain the
  #     subagent's in-progress work. Skip the codex retry ladder entirely
  #     and jump straight to consuming the fallback result.
  #   * dispatched | gate-check: genuinely mid-flight / interrupted.
  #     Wipe partial state and restart from a clean BASE worktree.
  #   * anything else (fresh run, or unknown): set up the worktree if it
  #     doesn't already exist. Nothing to clean.
  prior_status=""
  if [ -r "$WORK/state.json" ]; then
    prior_status="$(jq -r --argjson w "$WAVE" --argjson n "$num" \
      '.waves[] | select(.wave == $w) | .tasks[] | select(.num == $n) | .status // ""' \
      "$WORK/state.json" 2>/dev/null || echo "")"
  fi
  resume_fallback=0
  case "$prior_status" in
    claude-fallback)
      # Normally we preserve everything and resume the fallback flow.
      # BUT if the worktree is gone (e.g. --resume --force-clean, or the
      # user manually deleted \$WORK/\<slug\>), the subagent's edits are
      # already gone — there's nothing to resume. Wipe stale fallback
      # markers and fall through to a fresh dispatch from attempt 1.
      if [ -d "$wt" ]; then
        resume_fallback=1
        # Do NOT touch worktree or fallback marker files.
      else
        rm -f "$sid_file" "$prompt_file" 2>/dev/null || true
        # Clean both the legacy unversioned paths and any generation-suffixed
        # ones so stale fallback replies can't leak into a fresh attempt.
        rm -f "$WORK"/needs-spec-check.$WAVE.$num.*.json \
              "$WORK"/spec-check-result.$WAVE.$num.*.json \
              "$WORK"/needs-claude-fallback.$WAVE.$num.json \
              "$WORK"/needs-claude-fallback.$WAVE.$num.*.json \
              "$WORK"/claude-fallback-result.$WAVE.$num.json \
              "$WORK"/claude-fallback-result.$WAVE.$num.*.json \
              "$WORK"/findings.$WAVE.$num.*.txt \
              "$WORK"/findings.$WAVE.$num.*.txt.review \
              "$WORK"/diff.$WAVE.$num.txt \
              2>/dev/null || true
        "$BIN/codex-worktree" setup "$WORK" "$slug" "$BASE" > /dev/null
      fi
      ;;
    dispatched|gate-check)
      if [ -d "$wt" ]; then
        "$BIN/codex-worktree" teardown "$WORK" "$slug" > /dev/null 2>&1 || true
      fi
      rm -f "$sid_file" "$prompt_file" 2>/dev/null || true
      # Fallback markers use either the legacy unversioned path
      # (needs-claude-fallback.<W>.<N>.json) or the new generation-suffixed
      # path (needs-claude-fallback.<W>.<N>.<gen>.json). Spec-check markers
      # already use per-attempt suffixing. Clean every variant.
      rm -f "$WORK"/needs-spec-check.$WAVE.$num.*.json \
            "$WORK"/spec-check-result.$WAVE.$num.*.json \
            "$WORK"/needs-claude-fallback.$WAVE.$num.json \
            "$WORK"/needs-claude-fallback.$WAVE.$num.*.json \
            "$WORK"/claude-fallback-result.$WAVE.$num.json \
            "$WORK"/claude-fallback-result.$WAVE.$num.*.json \
            "$WORK"/findings.$WAVE.$num.*.txt \
            "$WORK"/findings.$WAVE.$num.*.txt.review \
            "$WORK"/diff.$WAVE.$num.txt \
            2>/dev/null || true
      "$BIN/codex-worktree" setup "$WORK" "$slug" "$BASE" > /dev/null
      ;;
    *)
      if [ ! -d "$wt" ]; then
        "$BIN/codex-worktree" setup "$WORK" "$slug" "$BASE" > /dev/null
      fi
      ;;
  esac

  # Don't mark `dispatched` here yet when we're about to enter the
  # fallback-resume branch: that would briefly regress the task's status and,
  # if the process is interrupted in that window, the next --resume would
  # treat it as a normal dispatched-task interruption and wipe the subagent's
  # preserved worktree + markers. For the fallback-resume path, leave the
  # status as `claude-fallback` (it already is).
  if [ "$resume_fallback" -ne 1 ]; then
    "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status dispatched
  fi

  # Resume from claude-fallback: skip the codex retry ladder and consume an
  # existing (or pending) fallback result directly. The in-progress subagent
  # edits live in $wt; the marker files may or may not already exist.
  if [ "$resume_fallback" -eq 1 ]; then
    # If the prior run still has a live, unconsumed fallback marker, consume
    # it in place (worker may have already replied). Otherwise try a fresh
    # gate — the prior run may have been interrupted right after consuming
    # its reply but before codex-gate updated task status, in which case the
    # subagent's edits are already in $wt and a gate pass is all we need.
    #
    # Pair marker ↔ result by generation: pick the newest available marker,
    # then derive its matching result path via the standard substitution. A
    # stale reply from an older generation is ignored (wrong path).
    local fb_gen fb_marker fb_result
    fb_marker=""
    fb_result=""
    # Find the newest marker (by mtime) across both layouts. Use a
    # NUL-delimited sort to stay safe on paths containing spaces — the
    # earlier `for f in $(ls -t ...)` pattern word-split paths like
    # "/var/Application Support/.../W.N.json".
    fb_marker="$(find "$WORK" -maxdepth 1 -type f \
      \( -name "needs-claude-fallback.$WAVE.$num.*.json" \
         -o -name "needs-claude-fallback.$WAVE.$num.json" \) \
      -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -n1)"
    [ -n "$fb_marker" ] && [ -r "$fb_marker" ] || fb_marker=""
    if [ -n "$fb_marker" ]; then
      # Derived result path must match marker generation exactly.
      fb_result="$(echo "$fb_marker" | sed 's/needs-claude-fallback/claude-fallback-result/')"
      [ -r "$fb_result" ] || fb_result=""
    else
      # No marker: we CANNOT safely pick a result by mtime because a
      # delayed reply from an older generation might be newer than the
      # correct current-generation result (or vice versa). Without the
      # marker to anchor which generation is authoritative, any existing
      # result file is suspect. Treat this as 'no reply' — the no-marker-
      # no-result branch below will re-gate (which covers the common
      # 'prior run consumed the reply but crashed before state update'
      # case) and only emit a fresh fallback request on gate failure.
      # Also delete any dangling result files so they can't be consumed
      # on a later attempt.
      find "$WORK" -maxdepth 1 -type f \
        \( -name "claude-fallback-result.$WAVE.$num.*.json" \
           -o -name "claude-fallback-result.$WAVE.$num.json" \) \
        -print0 2>/dev/null | xargs -0 rm -f 2>/dev/null || true
      fb_result=""
    fi

    # If no marker AND no result survived, or if a marker survived with no
    # matching result (the prior worker may have been interrupted after
    # consuming its own reply but before removing its marker), always try
    # a fresh gate first against the subagent's existing edits — in both
    # cases the worktree may already be good enough to PASS. Only emit a
    # NEW fallback request if the gate still fails.
    if [ -z "$fb_result" ]; then
      GATE_ATTEMPT="4-resume-regate" \
      gate_status="$("$BIN/codex-gate" \
        --worktree "$wt" --work-dir "$WORK" \
        --wave "$WAVE" --task "$num" --task-slug "$slug" \
        --base "$BASE" --test-cmd "$test_cmd" 2>/dev/null || echo FAIL)"
      if [ "$gate_status" = "PASS" ]; then
        # Clean any leftover stale marker before returning so a later
        # attempt doesn't see it as active.
        [ -n "$fb_marker" ] && rm -f "$fb_marker" 2>/dev/null || true
        "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status passed-gate
        return 0
      fi
      # Gate still red → emit a fresh fallback request with a new
      # generation. Delete any stale marker first so a delayed reply to
      # IT can't satisfy the new request's wait loop.
      [ -n "$fb_marker" ] && rm -f "$fb_marker" 2>/dev/null || true
      regate_findings="$WORK/findings.$WAVE.$num.4-resume-regate.txt"
      if [ ! -r "$regate_findings" ]; then
        regate_findings="$WORK/findings.$WAVE.$num.3.txt"
      fi
      fb_gen="$(fb_gen_new)"
      fb_marker="$WORK/needs-claude-fallback.$WAVE.$num.$fb_gen.json"
      fb_result="$WORK/claude-fallback-result.$WAVE.$num.$fb_gen.json"
      jq -n \
        --argjson w "$WAVE" --argjson t "$num" \
        --arg slug "$slug" --arg wt "$wt" \
        --arg base "$BASE" --arg findings "$regate_findings" \
        --arg plan_json "$PLAN_JSON" \
        --arg now "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '{wave:$w, task:$t, slug:$slug, worktree_path:$wt, base:$base,
          findings_file:$findings, plan_json:$plan_json, requested_at:$now,
          resumed:true}' \
        > "$fb_marker"
    fi
    local waited=0
    while [ ! -r "$fb_result" ]; do
      sleep 5; waited=$((waited + 5))
      if [ "$waited" -gt 1800 ]; then
        "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status escalated
        return 2
      fi
    done
    local res
    res="$(jq -r '.status' "$fb_result")"
    rm -f "$fb_result"
    if [ "$res" = "DONE" ] || [ "$res" = "DONE_WITH_CONCERNS" ]; then
      GATE_ATTEMPT="4-resume" \
      gate_status="$("$BIN/codex-gate" \
        --worktree "$wt" --work-dir "$WORK" \
        --wave "$WAVE" --task "$num" --task-slug "$slug" \
        --base "$BASE" --test-cmd "$test_cmd")"
      if [ "$gate_status" = "PASS" ]; then
        "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status passed-gate
        return 0
      fi
    fi
    "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status escalated
    return 2
  fi

  while :; do
    render_prompt "$num" "$findings" "$forbidden" > "$prompt_file"

    local status gate_status
    status="$("$BIN/codex-dispatch-task" \
      --worktree "$wt" \
      --log "$LOGS/$slug.log" \
      --prompt-file "$prompt_file" \
      --reasoning "$reasoning" \
      --session-file "$sid_file" \
      --timeout "$TIMEOUT")"

    "$BIN/codex-state" append-attempt "$WORK" \
      --wave "$WAVE" --task "$num" \
      --impl "codex-$reasoning" \
      --session-id "$(cat "$sid_file" 2>/dev/null || echo '')" \
      --result "$status"

    if [ "$status" = "BLOCKED" ] || [ "$status" = "NEEDS_CONTEXT" ]; then
      gate_status="FAIL dispatch"
    else
      "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status gate-check
      GATE_ATTEMPT="$attempt" \
        gate_status="$("$BIN/codex-gate" \
          --worktree "$wt" \
          --work-dir "$WORK" \
          --wave "$WAVE" --task "$num" --task-slug "$slug" \
          --base "$BASE" \
          --test-cmd "$test_cmd")"
    fi

    if [ "$gate_status" = "PASS" ]; then
      "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status passed-gate
      return 0
    fi

    findings="$WORK/findings.$WAVE.$num.$attempt.txt"
    attempt=$((attempt + 1))
    case "$attempt" in
      2) reasoning="high" ;;
      3) reasoning="xhigh" ;;
      4)
        "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status claude-fallback
        # Generation suffix keeps a stale reply from a previous --force-clean
        # or crashed run from being consumed by this attempt.
        local fb_gen4 fb_marker4 fb_result4
        fb_gen4="$(fb_gen_new)"
        fb_marker4="$WORK/needs-claude-fallback.$WAVE.$num.$fb_gen4.json"
        fb_result4="$WORK/claude-fallback-result.$WAVE.$num.$fb_gen4.json"
        jq -n \
          --argjson w "$WAVE" --argjson t "$num" \
          --arg slug "$slug" --arg wt "$wt" \
          --arg base "$BASE" --arg findings "$findings" \
          --arg plan_json "$PLAN_JSON" \
          --arg now "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
          '{wave:$w, task:$t, slug:$slug, worktree_path:$wt, base:$base,
            findings_file:$findings, plan_json:$plan_json, requested_at:$now}' \
          > "$fb_marker4"
        local waited=0
        while [ ! -r "$fb_result4" ]; do
          sleep 5; waited=$((waited + 5))
          if [ "$waited" -gt 1800 ]; then
            "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status escalated
            return 2
          fi
        done
        local res
        res="$(jq -r '.status' "$fb_result4")"
        rm -f "$fb_result4"
        if [ "$res" = "DONE" ] || [ "$res" = "DONE_WITH_CONCERNS" ]; then
          GATE_ATTEMPT="$attempt" \
          gate_status="$("$BIN/codex-gate" \
            --worktree "$wt" --work-dir "$WORK" \
            --wave "$WAVE" --task "$num" --task-slug "$slug" \
            --base "$BASE" --test-cmd "$test_cmd")"
          if [ "$gate_status" = "PASS" ]; then
            "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status passed-gate
            return 0
          fi
        fi
        "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$num" --status escalated
        return 2
        ;;
    esac
  done
}

# Dispatch wave with a max-parallel ceiling.
# Portable pattern (no `wait -n`): maintain an active-pids list; whenever the
# list reaches MAX_PARALLEL, poll every ~0.2s for any child to exit, reap it,
# then continue.
active_pids=()
failed=0

reap_any() {
  # Blocks until at least one active pid exits; prunes all exited pids; returns.
  while :; do
    local still_alive=()
    local reaped=0
    local p
    for p in "${active_pids[@]:-}"; do
      if [ -z "$p" ]; then continue; fi
      if kill -0 "$p" 2>/dev/null; then
        still_alive+=("$p")
      else
        if ! wait "$p"; then failed=$((failed + 1)); fi
        reaped=1
      fi
    done
    active_pids=("${still_alive[@]:-}")
    if [ "$reaped" = "1" ]; then return 0; fi
    sleep 0.2
  done
}

reap_all() {
  local p
  for p in "${active_pids[@]:-}"; do
    [ -z "$p" ] && continue
    if ! wait "$p"; then failed=$((failed + 1)); fi
  done
  active_pids=()
}

STATE_JSON="$WORK/state.json"
for n in $wave_tasks; do
  # Skip tasks already in a terminal good state (passed-gate, merged) so
  # --resume after a partial wave doesn't re-dispatch accepted work, which
  # would regenerate commits from an already-advanced base and clobber
  # surviving worktrees.
  if [ -r "$STATE_JSON" ]; then
    task_state="$(jq -r --argjson w "$WAVE" --argjson n "$n" \
      '.waves[] | select(.wave == $w) | .tasks[] | select(.num == $n) | .status' \
      "$STATE_JSON" 2>/dev/null || echo "")"
    case "$task_state" in
      passed-gate|merged)
        echo "[WAVE $WAVE] task $n already $task_state; skipping" >&2
        continue
        ;;
    esac
  fi

  process_one "$n" &
  active_pids+=("$!")
  while [ "${#active_pids[@]}" -ge "$MAX_PARALLEL" ]; do
    reap_any
  done
done

reap_all

if [ "$failed" -gt 0 ]; then
  echo "wave $WAVE: $failed task(s) escalated" >&2
  exit 2
fi
exit 0
