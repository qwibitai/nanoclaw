#!/usr/bin/env bash
# Stage 2 gate: run `codex review --base <base>` in a worktree, emit PASS or FAIL.
# On FAIL, write the verbatim review output to --findings-file.
set -euo pipefail

CODEX="${CODEX_BIN:-codex}"
WT=""; BASE=""; FINDINGS=""
while [ $# -gt 0 ]; do
  case "$1" in
    --worktree)       WT="$2"; shift 2 ;;
    --base)           BASE="$2"; shift 2 ;;
    --findings-file)  FINDINGS="$2"; shift 2 ;;
    *) echo "unknown flag: $1" >&2; exit 2 ;;
  esac
done
: "${WT:?}" "${BASE:?}" "${FINDINGS:?}"

tmp="$(mktemp)"; trap 'rm -f "$tmp"' EXIT

# Invoke the same CLI directly here (we don't want the full skill preamble).
# NOTE: as of codex-cli 0.122, `codex review` rejects combining a [PROMPT]
# argument with `--base` ("the argument '[PROMPT]' cannot be used with
# '--base <BRANCH>'"). We used to pass a filesystem-boundary instruction as the
# prompt; we rely on the small, scoped diff (single task worktree) to keep
# codex review focused — it only sees `git diff BASE...HEAD` for the task.
(cd "$WT" && "$CODEX" review \
  --base "$BASE" \
  -c 'model_reasoning_effort="high"') > "$tmp" 2>&1

# Pass/fail heuristic: look for severity markers or the literal word FAIL / "blocking issue".
if grep -Eq '^\[(P0|P1|CRITICAL|MAJOR)\]|^FAIL$|^[[:space:]]*blocking issue' "$tmp"; then
  cp "$tmp" "$FINDINGS"
  echo "FAIL"
  exit 0
fi

echo "PASS"
