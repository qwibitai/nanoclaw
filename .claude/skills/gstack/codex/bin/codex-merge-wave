#!/usr/bin/env bash
# Squash-merge each passed-gate task branch into the base branch in ascending
# task-number order. On conflict, abort that merge, mark the task BLOCKED with
# post-merge-conflict, and stop the wave.
#
# Flags:
#   --work-dir <dir>
#   --wave <N>
#   --base <ref>
#   --plan-json <file>
#
# After each successful merge, record `final_commit_on_base` in state.json and
# run the post-wave global test command. If red, escalate.
set -euo pipefail

WORK="" WAVE="" BASE="" PLAN_JSON="" ONLY_TASK=""
while [ $# -gt 0 ]; do
  case "$1" in
    --work-dir)  WORK="$2"; shift 2 ;;
    --wave)      WAVE="$2"; shift 2 ;;
    --base)      BASE="$2"; shift 2 ;;
    --plan-json) PLAN_JSON="$2"; shift 2 ;;
    --only-task) ONLY_TASK="$2"; shift 2 ;;
    *) echo "unknown flag: $1" >&2; exit 2 ;;
  esac
done
: "${WORK:?}" "${WAVE:?}" "${BASE:?}" "${PLAN_JSON:?}"

SKILL_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BIN="$SKILL_DIR/bin"

tasks="$(jq -r --argjson w "$WAVE" '.waves[] | select(.wave == $w) | .tasks | sort | .[]' "$PLAN_JSON")"
# With --only-task, merge only that task; leave other branches in this wave alone.
if [ -n "$ONLY_TASK" ]; then
  filtered=""
  for t in $tasks; do
    if [ "$t" = "$ONLY_TASK" ]; then filtered="$t"; fi
  done
  tasks="$filtered"
fi
plan_slug="$(basename "$WORK")"
repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

git checkout -q "$BASE"

STATE_JSON="$WORK/state.json"

# Track which task slugs we merged this run so we can defer their teardown
# until AFTER the post-wave global test passes. If the test fails, worktrees
# and branches stay alive so `codex-implement --resume` can re-run the test
# (or the user can inspect the per-task worktrees) without having to undo
# and re-dispatch the whole wave.
merged_this_run_slugs=""

for n in $tasks; do
  # Skip tasks already merged on a previous --resume.
  if [ -r "$STATE_JSON" ]; then
    task_state="$(jq -r --argjson w "$WAVE" --argjson n "$n" \
      '.waves[] | select(.wave == $w) | .tasks[] | select(.num == $n) | .status' \
      "$STATE_JSON" 2>/dev/null || echo "")"
    if [ "$task_state" = "merged" ]; then
      echo "[WAVE $WAVE] task $n already merged; skipping" >&2
      continue
    fi
  fi

  slug="$(jq -r --argjson n "$n" '.tasks[] | select(.num == $n) | .slug' "$PLAN_JSON")"
  heading="$(jq -r --argjson n "$n" '.tasks[] | select(.num == $n) | .heading' "$PLAN_JSON")"
  branch="codex/$plan_slug/$slug"

  if ! git merge --squash "$branch" 2>/dev/null; then
    git merge --abort 2>/dev/null || true
    "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$n" --status blocked
    echo "ESCALATE wave=$WAVE task=$n reason=post-merge-conflict" >&2
    exit 2
  fi

  msg="task $n: $heading

via /codex implement

Co-Authored-By: Codex (gpt-5-codex) <noreply@openai.com>
Co-Authored-By: Claude (claude-opus-4-6) <noreply@anthropic.com>"
  git commit -qm "$msg"
  sha="$(git rev-parse HEAD)"
  "$BIN/codex-state" set-task-commit "$WORK" --wave "$WAVE" --task "$n" --sha "$sha"
  "$BIN/codex-state" set-status      "$WORK" --wave "$WAVE" --task "$n" --status merged

  merged_this_run_slugs="$merged_this_run_slugs $slug"
done

# Run the post-wave global test BEFORE tearing anything down and BEFORE
# marking the wave completed. Task status is already `merged` (commits are on
# $BASE), but the wave invariant hasn't been validated yet. If the test
# fails, leave every branch and worktree from THIS run alive so the user and
# a subsequent --resume both have recovery options:
#   * User can inspect $WORK/<slug> worktrees to figure out what broke.
#   * --resume will re-run the global test against the already-merged commits
#     without re-dispatching tasks (task status=merged makes run-wave skip
#     them; codex-merge-wave skips them in its per-task loop above).
#
# In --only-task mode we skip both the global test and the wave-completion
# flag (the partial wave is not expected to satisfy the plan's full-wave
# invariant, and other tasks still need to run later). Also don't tear down
# worktrees for the unmerged tasks in that wave.
if [ -z "$ONLY_TASK" ]; then
  # Plan-level test_command runs only after the LAST declared wave (waves
  # execute in declaration order, not numeric order — so use the last
  # element of .waves[], not max of .waves[].wave). Running the test
  # earlier would break any plan where a later wave produces the artifact
  # the test inspects.
  last_wave="$(jq -r '.waves[-1].wave' "$PLAN_JSON")"
  is_final_wave=0
  if [ "$WAVE" = "$last_wave" ]; then is_final_wave=1; fi

  if [ "$is_final_wave" -eq 1 ]; then
    global_test="$(jq -r '.test_command' "$PLAN_JSON")"
    if [ -n "$global_test" ] && [ "$global_test" != "null" ]; then
      if ! bash -c "$global_test"; then
        "$BIN/codex-state" set-wave-status "$WORK" --wave "$WAVE" --status in_progress
        echo "ESCALATE wave=$WAVE reason=post-wave-global-test-failed" >&2
        echo "" >&2
        echo "  task worktrees preserved at $WORK/<slug> for inspection" >&2
        echo "  (every wave in the plan — the plan test could fail on a bug" >&2
        echo "  from any earlier wave)." >&2
        echo "" >&2
        echo "  TO REPAIR:" >&2
        echo "  (a) edit the code and commit the fix directly on $BASE," >&2
        echo "      then run 'codex-implement --resume <plan>'. Resume" >&2
        echo "      re-runs ONLY the plan-level test; it does not" >&2
        echo "      re-dispatch or re-squash merged tasks." >&2
        echo "  (b) run 'codex-implement --rollback <plan>' to revert every" >&2
        echo "      squash commit from this plan, then re-run from scratch" >&2
        echo "      after fixing the plan itself." >&2
        exit 2
      fi
    fi
  fi
  "$BIN/codex-state" set-wave-status "$WORK" --wave "$WAVE" --status completed
fi

# Teardown policy:
#   * `--only-task`: only the single merged task's worktree goes; every other
#     slug is untouched. BUT we also run the plan-level test as a minimum
#     sanity gate — a canary run with no Run: line and no plan-level check
#     would otherwise land with zero verification. If the plan-level test
#     fails under --only-task, leave the worktree in place and escalate.
#   * Full plan, non-final wave: preserve every merged-this-wave worktree.
#     If the final-wave plan test fails, these earlier-wave worktrees are
#     still inspectable (read-only — see what each task originally
#     produced). Actual repair goes through `git commit` directly on
#     $BASE; --resume re-runs only the plan test, it does not re-squash
#     edits made inside a preserved task worktree (merged tasks are
#     skipped by both run-wave and merge-wave).
#   * Full plan, final wave, plan test green: tear down EVERY slug in the
#     whole plan that still has a worktree (accumulated across all waves).
if [ -n "$ONLY_TASK" ]; then
  # --only-task sanity gate: run the plan-level test. Failure is FATAL —
  # the squash commit has already landed on BASE (bad commit on main) and
  # the user should decide: either the failure is because peer tasks
  # aren't merged yet (then use --rollback + a full run) or it's a real
  # problem with this task's output. Either way, don't silently tear
  # down + exit 0 with broken state.
  canary_test="$(jq -r '.test_command' "$PLAN_JSON")"
  canary_total_tasks="$(jq '.tasks | length' "$PLAN_JSON")"
  if [ -n "$canary_test" ] && [ "$canary_test" != "null" ] && [ "$canary_total_tasks" != "1" ]; then
    # Multi-task plan: a failing plan-level test is only acceptable if
    # it's because peer tasks haven't merged yet. Check whether EVERY
    # task other than the canary is already in terminal-good state; if
    # so, a failing plan test is a real bug and must be fatal. Otherwise
    # preserve the worktree + exit 0 with a warning.
    if ! bash -c "$canary_test" >/dev/null 2>&1; then
      peers_all_merged=1
      peer_nums="$(jq -r --argjson me "$ONLY_TASK" '.tasks[].num | select(. != $me)' "$PLAN_JSON")"
      for pn in $peer_nums; do
        peer_status="$(jq -r --argjson n "$pn" \
          '.waves[].tasks[] | select(.num == $n) | .status' \
          "$STATE_JSON" 2>/dev/null || echo "")"
        # Only `merged` means the peer's squash commit is on BASE.
        # `passed-gate` is a pre-merge state where the gate passed but
        # codex-merge-wave hasn't run on that peer yet — its changes are
        # NOT in the plan-level test target.
        if [ "$peer_status" != "merged" ]; then
          peers_all_merged=0
        fi
      done
      if [ "$peers_all_merged" -eq 1 ]; then
        echo "ESCALATE --only-task canary: plan-level test failed." >&2
        echo "  All peer tasks are already merged, so this failure is a" >&2
        echo "  real bug — not a 'peers not run yet' case." >&2
        echo "  Squash commit is already on $BASE. Inspect and use" >&2
        echo "  codex-implement --rollback if you want to revert." >&2
        echo "  Worktree preserved at $WORK/<slug>." >&2
        exit 2
      fi
      echo "WARNING: plan-level test failed under --only-task on a multi-task plan." >&2
      echo "  Peer tasks haven't all merged yet, so this may be expected." >&2
      echo "  Worktree preserved at $WORK/<slug> for inspection." >&2
      # Preserve worktree; don't tear down; exit 0.
      exit 0
    fi
  elif [ -n "$canary_test" ] && [ "$canary_test" != "null" ] && [ "$canary_total_tasks" = "1" ]; then
    # Single-task plan: plan-level test IS the whole plan's acceptance
    # test. Failure is a real bug.
    if ! bash -c "$canary_test"; then
      echo "ESCALATE --only-task canary: plan-level test failed." >&2
      echo "  Squash commit is already on $BASE — inspect, fix, and use" >&2
      echo "  codex-implement --rollback if you want to revert it." >&2
      echo "  Worktree preserved at $WORK/<slug>." >&2
      exit 2
    fi
  fi
  # Canary green (or no plan test): tear down.
  for sl in $merged_this_run_slugs; do
    [ -z "$sl" ] && continue
    "$BIN/codex-worktree" teardown "$WORK" "$sl" > /dev/null 2>&1 || true
  done
  # Wave completion after a successful --only-task canary: if every task
  # in the plan is now in state 'merged' (i.e. this invocation happened
  # to be the last remaining peer), mark the wave completed. Otherwise
  # stay in_progress — peers still need to run.
  all_merged=1
  for tn in $(jq -r '.tasks[].num' "$PLAN_JSON"); do
    tstat="$(jq -r --argjson n "$tn" \
      '.waves[].tasks[] | select(.num == $n) | .status' \
      "$STATE_JSON" 2>/dev/null || echo "")"
    [ "$tstat" = "merged" ] || { all_merged=0; break; }
  done
  if [ "$all_merged" -eq 1 ]; then
    "$BIN/codex-state" set-wave-status "$WORK" --wave "$WAVE" --status completed
  fi
elif [ "$is_final_wave" -eq 1 ]; then
  # Final wave green: tear down every worktree accumulated across the plan.
  all_slugs="$(jq -r '.tasks[].slug' "$PLAN_JSON")"
  for sl in $all_slugs; do
    [ -z "$sl" ] && continue
    if [ -d "$WORK/$sl" ]; then
      "$BIN/codex-worktree" teardown "$WORK" "$sl" > /dev/null 2>&1 || true
    fi
  done
fi
# Non-final wave (full plan): do NOT tear down any worktrees; preserve
# them so a later final-wave test failure remains recoverable.

exit 0
