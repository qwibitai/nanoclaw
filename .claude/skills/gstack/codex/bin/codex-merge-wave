#!/usr/bin/env bash
# Squash-merge each passed-gate task branch into the base branch in ascending
# task-number order. On conflict, abort that merge, mark the task BLOCKED with
# post-merge-conflict, and stop the wave.
#
# Flags:
#   --work-dir <dir>
#   --wave <N>
#   --base <ref>
#   --plan-json <file>
#
# After each successful merge, record `final_commit_on_base` in state.json and
# run the post-wave global test command. If red, escalate.
set -euo pipefail

WORK="" WAVE="" BASE="" PLAN_JSON="" ONLY_TASK=""
while [ $# -gt 0 ]; do
  case "$1" in
    --work-dir)  WORK="$2"; shift 2 ;;
    --wave)      WAVE="$2"; shift 2 ;;
    --base)      BASE="$2"; shift 2 ;;
    --plan-json) PLAN_JSON="$2"; shift 2 ;;
    --only-task) ONLY_TASK="$2"; shift 2 ;;
    *) echo "unknown flag: $1" >&2; exit 2 ;;
  esac
done
: "${WORK:?}" "${WAVE:?}" "${BASE:?}" "${PLAN_JSON:?}"

SKILL_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BIN="$SKILL_DIR/bin"

# Collect every slug that might have a surviving worktree/branch from this
# plan: state.json (original run) ∪ plan.json (current parse). Using both
# catches the case where the user edited task headings between runs.
all_plan_slugs() {
  {
    jq -r '.waves[].tasks[].slug // empty' "$WORK/state.json" 2>/dev/null
    jq -r '.tasks[].slug // empty' "$PLAN_JSON" 2>/dev/null
  } | awk 'NF && !seen[$0]++'
}

teardown_all_plan_worktrees() {
  local sl
  local slugs
  slugs="$(all_plan_slugs)"
  for sl in $slugs; do
    [ -z "$sl" ] && continue
    if [ -d "$WORK/$sl" ]; then
      "$BIN/codex-worktree" teardown "$WORK" "$sl" > /dev/null 2>&1 || true
    fi
  done
  # Prune stale linked-worktree metadata so branch -D can delete branches
  # whose worktree dir was removed out-of-band.
  git worktree prune > /dev/null 2>&1 || true
  for sl in $slugs; do
    [ -z "$sl" ] && continue
    if git show-ref --verify --quiet "refs/heads/codex/$plan_slug/$sl"; then
      git branch -D "codex/$plan_slug/$sl" > /dev/null 2>&1 || true
    fi
  done
}

tasks="$(jq -r --argjson w "$WAVE" '.waves[] | select(.wave == $w) | .tasks | sort | .[]' "$PLAN_JSON")"
# With --only-task, merge only that task; leave other branches in this wave alone.
if [ -n "$ONLY_TASK" ]; then
  filtered=""
  for t in $tasks; do
    if [ "$t" = "$ONLY_TASK" ]; then filtered="$t"; fi
  done
  tasks="$filtered"
fi
plan_slug="$(basename "$WORK")"
repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

git checkout -q "$BASE"

STATE_JSON="$WORK/state.json"

# Track which task slugs we merged this run so we can defer their teardown
# until AFTER the post-wave global test passes. If the test fails, worktrees
# and branches stay alive so `codex-implement --resume` can re-run the test
# (or the user can inspect the per-task worktrees) without having to undo
# and re-dispatch the whole wave.
merged_this_run_slugs=""

for n in $tasks; do
  # Skip tasks already merged on a previous --resume.
  if [ -r "$STATE_JSON" ]; then
    task_state="$(jq -r --argjson w "$WAVE" --argjson n "$n" \
      '.waves[] | select(.wave == $w) | .tasks[] | select(.num == $n) | .status' \
      "$STATE_JSON" 2>/dev/null || echo "")"
    if [ "$task_state" = "merged" ]; then
      echo "[WAVE $WAVE] task $n already merged; skipping" >&2
      continue
    fi
  fi

  slug="$(jq -r --argjson n "$n" '.tasks[] | select(.num == $n) | .slug' "$PLAN_JSON")"
  heading="$(jq -r --argjson n "$n" '.tasks[] | select(.num == $n) | .heading' "$PLAN_JSON")"
  branch="codex/$plan_slug/$slug"

  if ! git merge --squash "$branch" 2>/dev/null; then
    git merge --abort 2>/dev/null || true
    "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$n" --status blocked
    echo "ESCALATE wave=$WAVE task=$n reason=post-merge-conflict" >&2
    exit 2
  fi

  msg="task $n: $heading

via /codex implement

Co-Authored-By: Codex (gpt-5-codex) <noreply@openai.com>
Co-Authored-By: Claude (claude-opus-4-6) <noreply@anthropic.com>"
  git commit -qm "$msg"
  sha="$(git rev-parse HEAD)"
  "$BIN/codex-state" set-task-commit "$WORK" --wave "$WAVE" --task "$n" --sha "$sha"
  "$BIN/codex-state" set-status      "$WORK" --wave "$WAVE" --task "$n" --status merged

  merged_this_run_slugs="$merged_this_run_slugs $slug"
done

# Run the post-wave global test BEFORE tearing anything down and BEFORE
# marking the wave completed. Task status is already `merged` (commits are on
# $BASE), but the wave invariant hasn't been validated yet. If the test
# fails, leave every branch and worktree from THIS run alive so the user and
# a subsequent --resume both have recovery options:
#   * User can inspect $WORK/<slug> worktrees to figure out what broke.
#   * --resume will re-run the global test against the already-merged commits
#     without re-dispatching tasks (task status=merged makes run-wave skip
#     them; codex-merge-wave skips them in its per-task loop above).
#
# In --only-task mode we skip both the global test and the wave-completion
# flag (the partial wave is not expected to satisfy the plan's full-wave
# invariant, and other tasks still need to run later). Also don't tear down
# worktrees for the unmerged tasks in that wave.
# Compute is_final_wave ONCE, up front, so every later branch (including
# --only-task) sees it under `set -u`. Waves execute in declaration order,
# not numeric order, so use .waves[-1].wave (not max).
last_wave="$(jq -r '.waves[-1].wave' "$PLAN_JSON")"
is_final_wave=0
if [ "$WAVE" = "$last_wave" ]; then is_final_wave=1; fi

if [ -z "$ONLY_TASK" ]; then
  # Plan-level test_command runs only after the LAST declared wave.
  # Running the test earlier would break any plan where a later wave
  # produces the artifact the test inspects.

  PLAN_TEST_OK_SENTINEL="$WORK/plan-test-passed"

  if [ "$is_final_wave" -eq 1 ]; then
    global_test="$(jq -r '.test_command' "$PLAN_JSON")"
    # If the sentinel exists, the plan test already passed on a prior run;
    # don't re-run a potentially non-idempotent command.
    if [ -r "$PLAN_TEST_OK_SENTINEL" ]; then
      global_test=""
    fi
    if [ -n "$global_test" ] && [ "$global_test" != "null" ]; then
      # Run in a disposable worktree so side-effecting tests that mutate
      # files before failing don't leave the main checkout dirty (which
      # would block the next --resume on its clean-tree preflight).
      final_commit_sha="$(git rev-parse HEAD)"
      fin_wt="$WORK/.final-test.$$"
      rm -rf "$fin_wt" 2>/dev/null || true
      fin_passes=0
      if git worktree add -q --detach "$fin_wt" "$final_commit_sha" 2>/dev/null; then
        # Export REPO_ROOT so plan Test commands can reference the repo root
        # explicitly without hardcoding paths. The subshell's cwd is already
        # $fin_wt, so relative paths work too — REPO_ROOT just lets authors
        # write `cd "$REPO_ROOT" && ...` or `pytest "$REPO_ROOT/tests/..."`
        # without relying on implicit cwd. Prior to this, it was too easy to
        # write `cd ~/repo/$UNSUBSTITUTED && ...` and silently land in the
        # wrong directory when the shell var wasn't expanded.
        if (cd "$fin_wt" && REPO_ROOT="$fin_wt" bash -c "$global_test"); then
          fin_passes=1
        fi
        git worktree remove -f "$fin_wt" 2>/dev/null || rm -rf "$fin_wt" 2>/dev/null || true
        git worktree prune 2>/dev/null || true
      fi
      if [ "$fin_passes" -eq 0 ]; then
        "$BIN/codex-state" set-wave-status "$WORK" --wave "$WAVE" --status in_progress
        echo "ESCALATE wave=$WAVE reason=post-wave-global-test-failed" >&2
        echo "" >&2
        echo "  task worktrees preserved at $WORK/<slug> for inspection" >&2
        echo "  (every wave in the plan — the plan test could fail on a bug" >&2
        echo "  from any earlier wave)." >&2
        echo "" >&2
        echo "  Two things could have gone wrong here — check WHICH before repairing:" >&2
        echo "  1. Plan-level Test command is malformed (typo, undefined shell var," >&2
        echo "     bad cd path, missing binary). The per-task gates all passed; the" >&2
        echo "     merged commits on $BASE are correct. Fix: re-run the Test command" >&2
        echo "     manually — if it passes standalone, the plan-level command in your" >&2
        echo "     plan needs a typo fix. No rollback needed; commit a plan edit and" >&2
        echo "     keep moving." >&2
        echo "  2. An individual task's code actually broke the plan-level test." >&2
        echo "     Fix: run 'codex-implement --rollback <plan>' to revert every squash" >&2
        echo "     commit from this plan, fix the offending task spec, re-run from" >&2
        echo "     scratch. Direct ad-hoc commits on $BASE are NOT tracked by --rollback" >&2
        echo "     and can leave orphan changes or cause revert conflicts on a later" >&2
        echo "     rollback; fix the plan so its own tasks produce the correct" >&2
        echo "     acceptance state." >&2
        exit 2
      fi
      # Plan test just passed — persist the flag so later --resume runs
      # (and a follow-up --only-task) don't re-execute a potentially
      # non-idempotent command.
      touch "$PLAN_TEST_OK_SENTINEL"
    fi
  fi
  "$BIN/codex-state" set-wave-status "$WORK" --wave "$WAVE" --status completed
fi

# Teardown policy:
#   * `--only-task`: only the single merged task's worktree goes; every other
#     slug is untouched. BUT we also run the plan-level test as a minimum
#     sanity gate — a canary run with no Run: line and no plan-level check
#     would otherwise land with zero verification. If the plan-level test
#     fails under --only-task, leave the worktree in place and escalate.
#   * Full plan, non-final wave: preserve every merged-this-wave worktree.
#     If the final-wave plan test fails, these earlier-wave worktrees are
#     still inspectable (read-only — see what each task originally
#     produced). Actual repair goes through `git commit` directly on
#     $BASE; --resume re-runs only the plan test, it does not re-squash
#     edits made inside a preserved task worktree (merged tasks are
#     skipped by both run-wave and merge-wave).
#   * Full plan, final wave, plan test green: tear down EVERY slug in the
#     whole plan that still has a worktree (accumulated across all waves).
if [ -n "$ONLY_TASK" ]; then
  # --only-task sanity gate: run the plan-level test. Failure is FATAL —
  # the squash commit has already landed on BASE (bad commit on main) and
  # the user should decide: either the failure is because peer tasks
  # aren't merged yet (then use --rollback + a full run) or it's a real
  # problem with this task's output. Either way, don't silently tear
  # down + exit 0 with broken state.
  canary_test="$(jq -r '.test_command' "$PLAN_JSON")"
  canary_total_tasks="$(jq '.tasks | length' "$PLAN_JSON")"
  # Track whether the plan-level test already passed here so the completion
  # branch below doesn't re-run a potentially non-idempotent command.
  # Persist the "already passed" flag in a sentinel file so a later --resume
  # --only-task invocation also doesn't re-run the test (the same
  # non-idempotent concern, scaled across processes).
  PLAN_TEST_OK_SENTINEL="$WORK/plan-test-passed"
  canary_plan_test_passed=0
  if [ -r "$PLAN_TEST_OK_SENTINEL" ]; then
    canary_plan_test_passed=1
    # Don't re-run the canary test below — the sentinel means it already
    # passed (possibly from a crashed prior run, and the test may be
    # non-idempotent). Blank canary_test so both code paths short-circuit.
    canary_test=""
  fi
  if [ -n "$canary_test" ] && [ "$canary_test" != "null" ] && [ "$canary_total_tasks" != "1" ]; then
    # Multi-task plan: a failing plan-level test could be either
    #   (a) expected (peer tasks haven't merged yet), or
    #   (b) a real regression introduced by the canary task itself.
    # Distinguish by running the test on BASE~1 (the state BEFORE this
    # canary merge). If the pre-merge state ALSO fails, the failure is
    # peer-missing. If the pre-merge state passes, the canary
    # introduced the regression — FAIL and revert the squash commit.
    # Run BOTH the post-canary test and the pre-canary probe in DISPOSABLE
    # worktrees so side-effecting plan tests (ones that write files before
    # failing) don't dirty the main checkout. A dirty main checkout would
    # block the next --resume on its working-tree-clean preflight.
    canary_commit_sha="$(git rev-parse HEAD)"
    pre_canary_sha="$(git rev-parse HEAD~1 2>/dev/null || echo '')"

    post_wt="$WORK/.canary-post.$$"
    rm -rf "$post_wt" 2>/dev/null || true
    post_passes=0
    post_output_file="$WORK/.canary-post-output.$$"
    if git worktree add -q --detach "$post_wt" "$canary_commit_sha" 2>/dev/null; then
      if (cd "$post_wt" && REPO_ROOT="$post_wt" bash -c "$canary_test") > "$post_output_file" 2>&1; then
        post_passes=1
      fi
      git worktree remove -f "$post_wt" 2>/dev/null || rm -rf "$post_wt" 2>/dev/null || true
      git worktree prune 2>/dev/null || true
    fi

    if [ "$post_passes" -eq 0 ]; then
      pre_canary_passes=0
      pre_output_file="$WORK/.canary-pre-output.$$"
      if [ -n "$pre_canary_sha" ]; then
        pre_wt="$WORK/.canary-pre.$$"
        rm -rf "$pre_wt" 2>/dev/null || true
        if git worktree add -q --detach "$pre_wt" "$pre_canary_sha" 2>/dev/null; then
          if (cd "$pre_wt" && REPO_ROOT="$pre_wt" bash -c "$canary_test") > "$pre_output_file" 2>&1; then
            pre_canary_passes=1
          fi
          git worktree remove -f "$pre_wt" 2>/dev/null || rm -rf "$pre_wt" 2>/dev/null || true
          git worktree prune 2>/dev/null || true
        fi
      fi
      # If both probes fail, compare the OUTPUT. If it differs substantively,
      # the canary introduced a NEW failure mode on top of the peer-missing
      # one and we must still treat it as a regression.
      canary_introduced_new_failure=0
      if [ "$pre_canary_passes" -eq 0 ] && [ -r "$post_output_file" ] && [ -r "$pre_output_file" ]; then
        # Ignore paths and git shas that legitimately differ across worktrees.
        if ! diff -q \
          <(sed -E "s|$WORK/[^ ]*||g; s|[0-9a-f]{7,40}|<sha>|g" "$pre_output_file") \
          <(sed -E "s|$WORK/[^ ]*||g; s|[0-9a-f]{7,40}|<sha>|g" "$post_output_file") \
          > /dev/null 2>&1; then
          canary_introduced_new_failure=1
        fi
      fi
      if [ "$pre_canary_passes" -eq 1 ] || [ "$canary_introduced_new_failure" -eq 1 ]; then
        echo "ESCALATE --only-task canary: plan-level test passed on BASE but" >&2
        echo "  fails after this canary merged. The canary task itself broke" >&2
        echo "  an existing invariant. Undoing the squash commit…" >&2
        # Hard-reset to the pre-canary state. This is safe here because we
        # just made the squash commit ourselves, nothing else has happened
        # since, and the disposable-worktree checks keep the main checkout
        # clean. reset is atomic: no partial failure to worry about.
        if ! git reset --hard "$pre_canary_sha" > /dev/null 2>&1; then
          echo "  ERROR: failed to reset $BASE to $pre_canary_sha." >&2
          echo "  Bad commit may still be on $BASE — inspect manually and" >&2
          echo "  use codex-implement --rollback to revert." >&2
          # Leave the commit recorded so --rollback can still revert it.
          "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$ONLY_TASK" --status escalated
          exit 2
        fi
        # Reset succeeded; clear the recorded final_commit_on_base so
        # --rollback doesn't try to revert a commit that no longer exists.
        "$BIN/codex-state" set-task-commit "$WORK" --wave "$WAVE" --task "$ONLY_TASK" --sha ""
        "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$ONLY_TASK" --status escalated
        rm -f "$post_output_file" "$pre_output_file" 2>/dev/null || true
        echo "  Worktree preserved at $WORK/<slug>." >&2
        exit 2
      fi
      # Pre-canary also failed with the SAME output. Normally this is the
      # peer-missing case. BUT if this canary just merged the LAST
      # remaining task in the plan, there ARE no missing peers — a
      # failing plan test is a real bug regardless of pre/post similarity.
      plan_complete_now=1
      for tn in $(jq -r '.tasks[].num' "$PLAN_JSON"); do
        tstat="$(jq -r --argjson n "$tn" \
          '.waves[].tasks[] | select(.num == $n) | .status' \
          "$STATE_JSON" 2>/dev/null || echo "")"
        [ "$tstat" = "merged" ] || { plan_complete_now=0; break; }
      done
      if [ "$plan_complete_now" -eq 1 ]; then
        echo "ESCALATE --only-task canary completed the plan but the plan-level" >&2
        echo "  test is still failing. No unmerged peers left — this is a real" >&2
        echo "  plan failure. Undoing the squash commit…" >&2
        if ! git reset --hard "$pre_canary_sha" > /dev/null 2>&1; then
          echo "  ERROR: failed to reset $BASE to $pre_canary_sha." >&2
          echo "  Bad commit may still be on $BASE — inspect manually and" >&2
          echo "  use codex-implement --rollback to revert." >&2
          "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$ONLY_TASK" --status escalated
          rm -f "$post_output_file" "$pre_output_file" 2>/dev/null || true
          exit 2
        fi
        "$BIN/codex-state" set-task-commit "$WORK" --wave "$WAVE" --task "$ONLY_TASK" --sha ""
        "$BIN/codex-state" set-status "$WORK" --wave "$WAVE" --task "$ONLY_TASK" --status escalated
        echo "  Worktree preserved at $WORK/<slug>." >&2
        echo "  Fix the plan (task specs / plan-level Test command:) and" >&2
        echo "  re-run. --rollback is already clean." >&2
        rm -f "$post_output_file" "$pre_output_file" 2>/dev/null || true
        exit 2
      fi
      echo "WARNING: plan-level test failed under --only-task on a multi-task plan," >&2
      echo "  but was also failing on BASE before this canary merged with" >&2
      echo "  substantively identical output." >&2
      echo "  Peer tasks likely haven't all merged yet. Worktree preserved" >&2
      echo "  at $WORK/<slug> for inspection." >&2
      rm -f "$post_output_file" "$pre_output_file" 2>/dev/null || true
      # Peer-missing at PLAN level doesn't mean peer-missing at WAVE level.
      # If this canary merge completes the current wave's own tasks, mark
      # the wave completed so later --resume doesn't revisit it (the plan
      # as a whole is incomplete, but THIS WAVE is done).
      wave_all_merged_pm=1
      for tn in $(jq -r --argjson w "$WAVE" \
        '.waves[] | select(.wave == $w) | .tasks[]' "$PLAN_JSON"); do
        tstat_pm="$(jq -r --argjson n "$tn" \
          '.waves[].tasks[] | select(.num == $n) | .status' \
          "$STATE_JSON" 2>/dev/null || echo "")"
        [ "$tstat_pm" = "merged" ] || { wave_all_merged_pm=0; break; }
      done
      if [ "$wave_all_merged_pm" -eq 1 ] && [ "$is_final_wave" -ne 1 ]; then
        "$BIN/codex-state" set-wave-status "$WORK" --wave "$WAVE" --status completed
      fi
      # Preserve worktree; don't tear down; exit 0.
      exit 0
    else
      rm -f "$post_output_file" 2>/dev/null || true
      canary_plan_test_passed=1
      # Do NOT write the sentinel here. The canary's plan test passed
      # with SOME tasks still unmerged; the sentinel is reserved for
      # "plan test passed with ALL plan tasks merged". Writing it here
      # would let a later full run skip plan validation after the
      # remaining tasks merge (their changes never get test-gated).
    fi
  elif [ -n "$canary_test" ] && [ "$canary_test" != "null" ] && [ "$canary_total_tasks" = "1" ]; then
    # Single-task plan: plan-level test IS the whole plan's acceptance
    # test. Failure is a real bug. Run in a disposable worktree so
    # side-effecting tests don't dirty the main checkout.
    st_canary_sha="$(git rev-parse HEAD)"
    st_wt="$WORK/.canary-single.$$"
    rm -rf "$st_wt" 2>/dev/null || true
    st_passes=0
    if git worktree add -q --detach "$st_wt" "$st_canary_sha" 2>/dev/null; then
      if (cd "$st_wt" && REPO_ROOT="$st_wt" bash -c "$canary_test"); then
        st_passes=1
      fi
      git worktree remove -f "$st_wt" 2>/dev/null || rm -rf "$st_wt" 2>/dev/null || true
      git worktree prune 2>/dev/null || true
    fi
    if [ "$st_passes" -eq 0 ]; then
      echo "ESCALATE --only-task canary: plan-level test failed." >&2
      echo "  Squash commit is already on $BASE — inspect, fix, and use" >&2
      echo "  codex-implement --rollback if you want to revert it." >&2
      echo "  Worktree preserved at $WORK/<slug>." >&2
      exit 2
    fi
    canary_plan_test_passed=1
    # Single-task plan: a canary that passes IS the whole-plan test.
    # Safe to write the sentinel so --resume won't re-run the test.
    touch "$PLAN_TEST_OK_SENTINEL"
  fi
  # Canary green (or no plan test): tear down.
  for sl in $merged_this_run_slugs; do
    [ -z "$sl" ] && continue
    "$BIN/codex-worktree" teardown "$WORK" "$sl" > /dev/null 2>&1 || true
  done
  # Wave completion after a successful --only-task canary. Two cases:
  # (a) This is NOT the final wave: mark completed once its own tasks are
  #     all merged. The plan-level test isn't run here — that's the
  #     final wave's job.
  # (b) This IS the final wave: only mark completed if EVERY task across
  #     the whole plan is now merged AND the plan-level test passes.
  #     Otherwise a canary run of just the final wave's tasks would skip
  #     the plan test and be recorded as completed, so a later --resume
  #     of the earlier waves would bypass plan validation entirely.
  wave_all_merged=1
  for tn in $(jq -r --argjson w "$WAVE" \
    '.waves[] | select(.wave == $w) | .tasks[]' "$PLAN_JSON"); do
    tstat="$(jq -r --argjson n "$tn" \
      '.waves[].tasks[] | select(.num == $n) | .status' \
      "$STATE_JSON" 2>/dev/null || echo "")"
    [ "$tstat" = "merged" ] || { wave_all_merged=0; break; }
  done
  if [ "$wave_all_merged" -eq 1 ]; then
    if [ "$is_final_wave" -eq 1 ]; then
      # Require all plan tasks merged + plan test green before completion.
      plan_all_merged=1
      for tn in $(jq -r '.tasks[].num' "$PLAN_JSON"); do
        tstat="$(jq -r --argjson n "$tn" \
          '.waves[].tasks[] | select(.num == $n) | .status' \
          "$STATE_JSON" 2>/dev/null || echo "")"
        [ "$tstat" = "merged" ] || { plan_all_merged=0; break; }
      done
      if [ "$plan_all_merged" -eq 1 ]; then
        plan_test="$(jq -r '.test_command' "$PLAN_JSON")"
        plan_test_ok=1
        # If the canary above already ran the plan test and passed (either
        # in this process or on a prior run via the sentinel), don't run
        # it a second time — non-idempotent tests (e.g. one that creates
        # a sentinel file on first run) would pass once then fail here.
        if [ -n "$plan_test" ] && [ "$plan_test" != "null" ] && \
           [ "$canary_plan_test_passed" -ne 1 ]; then
          # REPO_ROOT="$PWD" matches the documented invariant in SKILL.md
          # so plan-level Test commands can reference $REPO_ROOT here too.
          # Without this, an --only-task completion-path plan_test that
          # uses $REPO_ROOT would fail with an unset variable while the
          # same command would pass under the main full-wave path.
          if ! REPO_ROOT="$PWD" bash -c "$plan_test" >/dev/null 2>&1; then
            plan_test_ok=0
          else
            touch "$PLAN_TEST_OK_SENTINEL"
          fi
        fi
        if [ "$plan_test_ok" -eq 1 ]; then
          "$BIN/codex-state" set-wave-status "$WORK" --wave "$WAVE" --status completed
          # Final wave + every plan task merged + plan test green: plan is
          # fully done. Tear down every preserved worktree/branch across
          # the plan (including slugs that may no longer appear in the
          # current plan.json if the plan was edited between runs).
          teardown_all_plan_worktrees
        else
          echo "ESCALATE wave=$WAVE reason=post-wave-global-test-failed (under --only-task)" >&2
          echo "  Plan-level test failed after the last --only-task merge." >&2
          echo "  Fix and re-run 'codex-implement --resume <plan>'." >&2
          exit 2
        fi
      fi
      # Otherwise: earlier waves still have unmerged peers. Leave the
      # final wave in_progress; a later invocation that merges those peers
      # will re-check and complete the plan.
    else
      "$BIN/codex-state" set-wave-status "$WORK" --wave "$WAVE" --status completed
      # If this non-final-wave merge happens to complete the whole plan
      # (user canaried a later wave first, then circled back to the
      # remaining earlier tasks), finalize the plan here: mark the final
      # wave completed and run the plan-wide cleanup. Otherwise the
      # previously-canaried final wave would stay in_progress with
      # preserved worktrees forever, requiring an extra --resume to
      # finish a plan whose commits are already all on BASE.
      plan_all_merged_now=1
      for tn in $(jq -r '.tasks[].num' "$PLAN_JSON"); do
        tstat="$(jq -r --argjson n "$tn" \
          '.waves[].tasks[] | select(.num == $n) | .status' \
          "$STATE_JSON" 2>/dev/null || echo "")"
        [ "$tstat" = "merged" ] || { plan_all_merged_now=0; break; }
      done
      if [ "$plan_all_merged_now" -eq 1 ]; then
        final_state="$(jq -r --argjson w "$last_wave" \
          '.waves[] | select(.wave == $w) | .status' \
          "$STATE_JSON" 2>/dev/null || echo "")"
        if [ "$final_state" != "completed" ]; then
          # Run the plan test (canary already passed if canary_plan_test_passed,
          # else run it now as the whole-plan gate).
          plan_test="$(jq -r '.test_command' "$PLAN_JSON")"
          plan_test_ok=1
          if [ -n "$plan_test" ] && [ "$plan_test" != "null" ] && \
             [ "$canary_plan_test_passed" -ne 1 ]; then
            # REPO_ROOT="$PWD" matches the documented invariant — see
            # the matching call site ~50 lines above for the rationale.
            if ! REPO_ROOT="$PWD" bash -c "$plan_test" >/dev/null 2>&1; then
              plan_test_ok=0
            else
              touch "$PLAN_TEST_OK_SENTINEL"
            fi
          fi
          if [ "$plan_test_ok" -eq 1 ]; then
            "$BIN/codex-state" set-wave-status "$WORK" --wave "$last_wave" --status completed
            teardown_all_plan_worktrees
          else
            echo "ESCALATE reason=post-wave-global-test-failed (under --only-task, non-final wave completing plan)" >&2
            echo "  Plan-level test failed after the last --only-task merge." >&2
            echo "  Fix and re-run 'codex-implement --resume <plan>'." >&2
            exit 2
          fi
        else
          # Final wave already completed (canaried earlier). Just clean up.
          teardown_all_plan_worktrees
        fi
      fi
    fi
  fi
elif [ "$is_final_wave" -eq 1 ]; then
  # Final wave green: tear down every worktree/branch accumulated across the
  # plan, using the union of slugs from state.json and the current plan.json
  # so edits to task headings between runs don't leak stale branches.
  teardown_all_plan_worktrees
fi
# Non-final wave (full plan): do NOT tear down any worktrees; preserve
# them so a later final-wave test failure remains recoverable.

exit 0
