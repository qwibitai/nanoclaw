# Assistant identity
# ASSISTANT_NAME="Andy"

# MemOS memory backend (optional — leave empty to use Claude's built-in memory)
# MEMOS_API_URL=http://localhost:8080/product
# MEMOS_API_AUTH=bee:yourpassword
# MEMOS_USER_ID=bee

# Container-specific MemOS URL (direct Docker network, no auth needed)
# Falls back to MEMOS_API_URL if not set
# MEMOS_CONTAINER_API_URL=http://memos-api:8000/product

# Docker network for container access to MemOS (optional)
# CONTAINER_NETWORK=memos_memos
