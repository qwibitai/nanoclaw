# Solo Vault — encrypted secret storage (optional)
# When set, credentials are fetched on-demand from Solo Vault instead of .env.
# Provision a service-scoped read token (not the admin key).
# SOLO_VAULT_TOKEN=svt_your_read_token_here
# SOLO_VAULT_URL=https://api.vault.jeffreykeyser.net
# SOLO_VAULT_PROJECT=nanoclaw
# SOLO_VAULT_ENV=production
