TELEGRAM_BOT_TOKEN=

# ── Multi-provider AI support ─────────────────────────────────────────────────
#
# Backbone providers (Anthropic-API-compatible, used by the agent runner).
# Set apiProvider in a group's containerConfig to choose which one to use.
#
ANTHROPIC_API_KEY=          # Direct Anthropic API (default backbone)
# CLAUDE_CODE_OAUTH_TOKEN=  # Alternative: Claude Pro OAuth (use instead of API key)
OPENROUTER_API_KEY=         # OpenRouter — route to any Claude model, cheaper pricing
                            # Set apiProvider: 'openrouter' in group containerConfig

# Secondary providers (tool-level calls from within the agent).
# Enable per group via enableSecondaryApis in containerConfig.
# The agent accesses these via NANOCLAW_*_URL and NANOCLAW_*_API_KEY env vars.
# Real keys are injected by the credential proxy; containers never see them.
#
OPENAI_API_KEY=             # OpenAI GPT models (gpt-4o, o3, etc.)
GEMINI_API_KEY=             # Google Gemini (gemini-2.0-flash, gemini-2.5-pro, etc.)
MOONSHOT_API_KEY=           # Moonshot AI Kimi models (kimi-k2, etc.)

# ── Optional proxy port overrides ────────────────────────────────────────────
# CREDENTIAL_PROXY_PORT=3001   # Anthropic proxy (default)
# OPENROUTER_PROXY_PORT=3002   # OpenRouter proxy (default)
# OPENAI_PROXY_PORT=3003       # OpenAI proxy (default)
# GEMINI_PROXY_PORT=3004       # Gemini proxy (default)
# MOONSHOT_PROXY_PORT=3005     # Moonshot proxy (default)
