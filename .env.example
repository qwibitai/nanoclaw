ASSISTANT_HAS_OWN_NUMBER=true

# WhatsApp Cloud API (Meta Business Platform)
# Get these from: Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Set this to any string you choose — use the same value in your Meta webhook config
WHATSAPP_VERIFY_TOKEN=
# Port the webhook HTTP server listens on inside the container (default: 3003)
# Expose this port via Docker (-p 3003:3003) and route public traffic to it from Meta
WHATSAPP_WEBHOOK_PORT=3003
