# === Required ===

# Anthropic API key (direct connection, not proxied via OneCLI)
ANTHROPIC_API_KEY=

# === Operator Identity ===

# Which operator this instance serves (selects dev-data/operators/<slug>/)
# Local dev instance
OPERATOR_SLUG=ymir
OPERATOR_NAME=Ymir

# === Agent ===

ASSISTANT_NAME=Nexus

# === Data ===

# Operator data directory (default: ../nexus-data for workspace layout)
# On Fly.io this is set to /app/dev-data by the Dockerfile
# NEXUS_DATA_DIR=../nexus-data

# === Networking ===

# Gateway HTTP port
GATEWAY_PORT=3001

# Agent connects to gateway here
# Local dev: http://localhost:3001
# Fly.io: http://gateway.process.<app-name>.internal:3001
GATEWAY_URL=http://localhost:3001

# === Optional ===

# OneCLI Cloud vault for service credentials (Discord, Resend)
# Get your key at https://app.onecli.sh
# ONECLI_API_KEY=

# Discord bot token — store in OneCLI Cloud, not here
# For local dev only: set directly. Production: use fly secrets set
# DISCORD_BOT_TOKEN=
