# Authentication: use ONE of the following
# Option A: Claude Code OAuth token (run `claude setup-token` to get one)
CLAUDE_CODE_OAUTH_TOKEN=

# Option B: Anthropic API key (pay-per-use)
# ANTHROPIC_API_KEY=

# Telegram bot token (required for Telegram channel)
TELEGRAM_BOT_TOKEN=

# Optional: pool of Telegram bots for agent swarm (comma-separated tokens)
# Each bot needs Group Privacy disabled in BotFather
# TELEGRAM_BOT_POOL=token1,token2,token3

# Groq API key for voice transcription (Whisper)
# GROQ_API_KEY=
# WHISPER_MODEL=whisper-large-v3-turbo

# Brave Search API key (enables WebSearch in agent containers)
# BRAVE_API_KEY=
