# NanoClaw Watch (T-Watch S3 firmware)
# Channel is opt-in: if WATCH_AUTH_TOKEN is empty, the HTTP server is not started.
# Generate the token with: openssl rand -hex 32
# The same value must be compiled into the watch firmware's src/config.h as WATCH_AUTH_TOKEN.
WATCH_AUTH_TOKEN=
WATCH_HTTP_PORT=3000
WATCH_HTTP_BIND=0.0.0.0
WATCH_JID=watch:scott
WATCH_GROUP_FOLDER=main
WATCH_SYNC_TIMEOUT_MS=12000

# Remotion Lambda (video generation) — Jorgenclaw uses these to render videos on AWS Lambda
# Obtain from AWS IAM console: create user 'remotion-jorgenclaw' with the policy at
# groups/main/remotion/aws-policies/user-policy.json (full walkthrough in aws-policies/README.md).
# REMOTION_SERVE_URL is set automatically after the first `npx remotion lambda sites create`.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
REMOTION_AWS_BUCKET=
REMOTION_SERVE_URL=
