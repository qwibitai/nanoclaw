# =============================================================================
# Authentication — use ONE of the following (or both for fallback)
# =============================================================================

# Option A: Claude Code OAuth token (subscription — run `claude setup-token`)
# Supports automatic refresh when using refresh tokens (sk-ant-ort01-*)
CLAUDE_CODE_OAUTH_TOKEN=

# Option B: Anthropic API key (pay-per-use)
# If both are set, API key is used as primary and OAuth as fallback
# ANTHROPIC_API_KEY=

# =============================================================================
# Channels
# =============================================================================

# Telegram bot token (required for Telegram channel)
TELEGRAM_BOT_TOKEN=

# Optional: pool of Telegram bots for agent swarm (comma-separated tokens)
# Each bot needs Group Privacy disabled in BotFather
# TELEGRAM_BOT_POOL=token1,token2,token3

# =============================================================================
# VPS / Resource Configuration
# =============================================================================

# Max concurrent containers (default: 5, use 1-2 for <=2GB RAM droplets)
# MAX_CONCURRENT_CONTAINERS=2

# Container hard timeout in ms (default: 1800000 = 30min)
# Reduce on memory-constrained VPS to prevent OOM
# CONTAINER_TIMEOUT=600000

# Idle timeout before container reaping in ms (default: 1800000 = 30min)
# Reduce on VPS to free memory faster
# IDLE_TIMEOUT=300000

# Credential proxy bind address (auto-detected by default)
# On VPS Linux: binds to docker0 bridge IP, falls back to 0.0.0.0
# Override if containers can't reach the proxy
# CREDENTIAL_PROXY_HOST=0.0.0.0

# Credential proxy port (default: 3001)
# CREDENTIAL_PROXY_PORT=3001

# =============================================================================
# Optional integrations
# =============================================================================

# Groq API key for voice transcription (Whisper)
# GROQ_API_KEY=
# WHISPER_MODEL=whisper-large-v3-turbo

# Brave Search API key (enables WebSearch in agent containers)
# BRAVE_API_KEY=
