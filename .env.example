# NanoClaw Environment Configuration
# Copy this file to .env and configure as needed.

# ==========================================
# Core Configuration
# ==========================================
# The name of your assistant (used for trigger commands like @Andy)
ASSISTANT_NAME=Andy

# ==========================================
# Authentication (Choose ONE of the following methods)
# ==========================================

# Method 1: Claude Code OAuth (Recommended - handled via /setup)
# CLAUDE_CODE_OAUTH_TOKEN=your-token-here

# Method 2: Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Method 3: AWS Bedrock (Uses your terminal's AWS credentials natively)
# If both of these are set, NanoClaw will use AWS Bedrock instead.
# AWS_REGION=us-east-1
# AWS_BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# ==========================================
# Advanced API Settings
# ==========================================
# ANTHROPIC_BASE_URL=https://api.anthropic.com
