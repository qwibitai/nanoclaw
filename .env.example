# Atlas Environment Variables

# Discord Bot Configuration
DISCORD_TOKEN=                    # Discord bot token (required)
DISCORD_CONTROL_CHANNEL_ID=       # Control channel ID for admin interface (required)

# Claude API
ANTHROPIC_API_KEY=                # Claude API key (required)

# GitHub Integration (for /build command)
GITHUB_TOKEN=                     # GitHub personal access token (optional, for PR creation)

# Logging
LOG_LEVEL=info                    # Options: trace, debug, info, warn, error

# Timezone
TZ=America/New_York               # Your timezone for scheduled tasks
