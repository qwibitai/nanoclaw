# アシスタント名
# デフォルト: 'Andy'
ASSISTANT_NAME=Andy

# アシスタントが独自の番号を持つかどうか ('true' に設定して有効化)
# デフォルト: false
ASSISTANT_HAS_OWN_NUMBER=false

# 設定ファイルのホームディレクトリパス
# デフォルト: システムホームディレクトリ (os.homedir())
# HOME=

# 使用するコンテナイメージ
# デフォルト: 'nanoclaw-agent:latest'
CONTAINER_IMAGE=nanoclaw-agent:latest

# コンテナタイムアウト (ミリ秒単位)
# デフォルト: 1800000
CONTAINER_TIMEOUT=1800000

# コンテナの最大出力サイズ (バイト単位)
# デフォルト: 10485760 (10MB)
CONTAINER_MAX_OUTPUT_SIZE=10485760

# 認証情報プロキシのポート番号
# デフォルト: 3001
CREDENTIAL_PROXY_PORT=3001

# コンテナシャットダウン前のアイドルタイムアウト (ミリ秒単位 / 最後の出力時点)
# デフォルト: 300000 (5分)
IDLE_TIMEOUT=300000

# 同時実行コンテナの最大数
# デフォルト: 5
MAX_CONCURRENT_CONTAINERS=5

# スケジュール済みタスクのタイムゾーン (例: cron 式)
# デフォルト: システムタイムゾーン (Intl.DateTimeFormat().resolvedOptions().timeZone)
TZ=

# Discord ボットトークン
# Discord チャンネルの使用に必須
DISCORD_BOT_TOKEN=

# --- LLM プロバイダー認証 (いずれか1つを設定) ---

# Anthropic API キー (プロキシ経由、推奨)
# ANTHROPIC_API_KEY=

# OpenAI API キー (プロキシ経由)
# OPENAI_API_KEY=

# Gemini API キー (直接注入、ALLOW_DIRECT_SECRET_INJECTION=true が必要)
# GEMINI_API_KEY=

# OpenAI Codex OAuth 認証ファイルパス
# デフォルト: ~/.codex/auth.json (`codex login` で作成)
# 直接注入のため ALLOW_DIRECT_SECRET_INJECTION=true が必要
# OAS_CODEX_AUTH_PATH=~/.codex/auth.json

# 直接シークレット注入を許可 (Gemini/Codex で必須)
# ALLOW_DIRECT_SECRET_INJECTION=true
