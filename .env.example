SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# GitHub token for gh CLI access inside agent containers (repo scope)
GITHUB_TOKEN=

# ── remote-log-analyzer credentials ─────────────────────────────────────────
# Global fallback — used when no per-host vars match
# RLA_USERNAME=admin
# RLA_PASSWORD=yourpassword
# RLA_PROTOCOL=ssh

# Per-host credentials (HOST_SLUG = hostname/IP uppercased, non-alphanumeric → _)
# Linux via SSH (e.g. host "web01.prod.example.com" → slug "WEB01_PROD_EXAMPLE_COM")
# RLA_WEB01_PROD_EXAMPLE_COM_USERNAME=admin
# RLA_WEB01_PROD_EXAMPLE_COM_PASSWORD=yourpassword
# RLA_WEB01_PROD_EXAMPLE_COM_PROTOCOL=ssh
#
# Windows via WinRM HTTP (port 5985, default)
# RLA_192_168_1_100_USERNAME=Administrator
# RLA_192_168_1_100_PASSWORD=yourpassword
# RLA_192_168_1_100_PROTOCOL=winrm
#
# Windows via WinRM HTTPS (port 5986, TLS)
# RLA_192_168_1_101_USERNAME=Administrator
# RLA_192_168_1_101_PASSWORD=yourpassword
# RLA_192_168_1_101_PROTOCOL=winrm
# RLA_192_168_1_101_PORT=5986
