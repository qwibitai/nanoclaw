# ── Docker / Deployment ───────────────────────────────────────────────────────
# Absolute path of this repo on the host machine.
# Required when running NanoClaw itself inside Docker (docker-compose).
# Not needed when running directly on the host (launchd / systemd).
# Example: /home/youruser/nanoclaw
HOST_PROJECT_ROOT=

# ── OneCLI ────────────────────────────────────────────────────────────────────
# URL of the OneCLI gateway. When running via docker-compose, this is set
# automatically in the compose file. Override here only for custom setups.
ONECLI_URL=http://localhost:10254

# Required for OneCLI (docker-compose). Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Optional — encrypts OneCLI secrets at rest. Generate with: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=

# Optional — OneCLI database credentials (defaults: onecli/onecli/onecli)
# POSTGRES_USER=onecli
# POSTGRES_PASSWORD=onecli
# POSTGRES_DB=onecli

# ── NanoClaw ──────────────────────────────────────────────────────────────────
# Name the assistant responds to (default: Andy)
# ASSISTANT_NAME=Andy

# Set to true if the assistant has its own dedicated phone number
# ASSISTANT_HAS_OWN_NUMBER=false

# Timezone for scheduled tasks and message formatting (IANA name)
# TZ=UTC

# ── Channels ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=

# ── Ollama ────────────────────────────────────────────────────────────────────
# OLLAMA_HOST=http://host.docker.internal:11434
