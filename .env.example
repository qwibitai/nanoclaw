# === Required ===
# Claude API (direct or via OpenRouter)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=          # Optional: https://openrouter.ai/api for OpenRouter
ANTHROPIC_AUTH_TOKEN=         # Optional: OpenRouter key (when using OpenRouter)

# === Discord ===
DISCORD_BOT_TOKEN=
DISCORD_ONLY=true

# === Optional: Phone (SignalWire) ===
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_API_TOKEN=
SIGNALWIRE_SPACE_URL=
SIGNALWIRE_PHONE_NUMBER=

# === Optional: Payments (x402) ===
BASE_WALLET_PRIVATE_KEY=
BASE_WALLET_ADDRESS=

# === Optional: Security ===
ALLOWED_USERS=               # Comma-separated Discord user IDs (empty = allow all)

# === Optional: Observer (conversation compression) ===
OBSERVER_ENABLED=true            # Set to false to disable observer
MIN_OBSERVER_MESSAGES=5          # Minimum user messages before observing

# === Optional: Model override for crons ===
# Per-task model set via schedule_task MCP tool, not env var

# === v2.0 Features ===
SOVEREIGN_MASTER_KEY=          # 64+ hex chars for encrypted secrets vault (unset = vault disabled)
# OPENAI_API_KEY=              # For hybrid memory embeddings (text-embedding-3-small)
# OPENAI_BASE_URL=             # Default: https://api.openai.com/v1

# Kill switches — set to 'false' to disable individual features
# PROVIDER_FALLBACK_ENABLED=true
# HYBRID_MEMORY_ENABLED=true
# SESSION_POOL_ENABLED=true
# MODEL_SWITCHING_ENABLED=true
# ROUTINE_ENGINE_ENABLED=true
# WEBHOOK_SERVER_ENABLED=true

# Pool & webhook settings
# MAX_POOL_SIZE=3              # Max warm containers in session pool
# POOL_IDLE_TIMEOUT=600000     # Idle timeout in ms (min 60000)
# WEBHOOK_PORT=3456            # Webhook server port (localhost only)
