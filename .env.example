# Assistant name
# Default: 'Andy'
ASSISTANT_NAME=Andy

# Whether the assistant has its own number (set to 'true' to enable)
# Default: false
ASSISTANT_HAS_OWN_NUMBER=false

# Home directory path for configuration files
# Default: System home directory (os.homedir())
# HOME=

# Container image to use
# Default: 'nanoclaw-agent:latest'
CONTAINER_IMAGE=nanoclaw-agent:latest

# Container timeout in milliseconds
# Default: 1800000
CONTAINER_TIMEOUT=1800000

# Maximum output size for the container in bytes
# Default: 10485760 (10MB)
CONTAINER_MAX_OUTPUT_SIZE=10485760

# Port for the credential proxy
# Default: 3001
CREDENTIAL_PROXY_PORT=3001

# Idle timeout in milliseconds before shutting down the container (last output)
# Default: 300000 (5 minutes)
IDLE_TIMEOUT=300000

# Maximum number of concurrent containers
# Default: 5
MAX_CONCURRENT_CONTAINERS=5

# Timezone for scheduled tasks (e.g., cron expressions)
# Default: System timezone (Intl.DateTimeFormat().resolvedOptions().timeZone)
TZ=

# Discord Bot Token
# Required for the Discord channel
DISCORD_BOT_TOKEN=
