# Embedded chat server (PWA on the host).
# When enabled, NanoClaw exposes an HTTP/WebSocket server that serves
# chat-pwa/ and registers a "local-chat" channel.
CHAT_SERVER_ENABLED=false

# Port to listen on. Default: 443 when TLS is configured (TLS_CERT+TLS_KEY
# both set), otherwise 3100. Override here if you want a non-standard port.
# Note: binding < 1024 as a non-root user requires
#   sudo setcap 'cap_net_bind_service=+ep' $(readlink -f $(which node))
# CHAT_SERVER_PORT=3100

# Bind address. Use 127.0.0.1 (default) for localhost-only.
# Set to 0.0.0.0 to expose on the LAN — REQUIRES CHAT_SERVER_TOKEN.
CHAT_SERVER_HOST=127.0.0.1

# Shared bearer token required from non-Tailscale clients when
# CHAT_SERVER_HOST is non-localhost. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# CHAT_SERVER_TOKEN=

# Optional TLS — paths to PEM cert and key. Both must be set to enable HTTPS.
# TLS_CERT=/path/to/cert.pem
# TLS_KEY=/path/to/key.pem
