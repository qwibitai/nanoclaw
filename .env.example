# === Required ===

# Anthropic API key (direct connection, not proxied via OneCLI)
ANTHROPIC_API_KEY=

# === Operator Identity ===

# Which operator this instance serves (selects dev-data/operators/<slug>/)
OPERATOR_SLUG=foundry
OPERATOR_NAME=Microgrid Foundry

# === Agent ===

ASSISTANT_NAME=Nexus

# === Networking ===

# Gateway HTTP port
GATEWAY_PORT=3001

# Worker connects to gateway here
# Local dev: http://localhost:3001
# Fly.io: http://gateway.process.<app-name>.internal:3001
GATEWAY_URL=http://localhost:3001

# === Optional ===

# OneCLI Cloud vault for service credentials (Discord, Resend)
# Get your key at https://app.onecli.sh
# ONECLI_API_KEY=
