# NanoClaw Environment Configuration
# Copy to .env and fill in your values.

# Required: Assistant identity
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false

# Required: At least one channel token
TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_POOL=token1,token2,token3  # Optional: agent swarm send-only bots

# Required: Claude API key (for agent containers)
ANTHROPIC_API_KEY=

# Optional: GitHub token (enables dev case issue tracking + case sync)
GITHUB_TOKEN=

# Optional: Case sync to cloud backend (GitHub Issues V1)
# Format: "owner/repo" — customer cases sync to this repo as GitHub Issues
# CASE_SYNC_REPO=Garsson-io/prints-demo-crm

# Optional: Container configuration
# CONTAINER_IMAGE=nanoclaw-agent:latest
# CONTAINER_TIMEOUT=1800000        # 30 min default
# CONTAINER_MAX_OUTPUT_SIZE=10485760  # 10MB default
# MAX_CONCURRENT_CONTAINERS=5
# IDLE_TIMEOUT=1800000             # 30 min — keep container alive after last result
# CREDENTIAL_PROXY_PORT=3001

# Optional: Message coalescing
# COALESCE_MS=500                  # Delay before starting container (batch rapid messages)
# MAX_DOWNLOAD_WAIT_MS=60000       # Max wait for in-progress file downloads

# Optional: Logging
# LOG_LEVEL=info                   # debug, info, warn, error
