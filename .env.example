# ─── Required: Messaging Channel ────────────────────────────────────────────
# Get from @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=

# ─── Required: AI Provider ───────────────────────────────────────────────────
# Provider: anthropic | openrouter | openai
# openrouter is recommended for free/cheap models
AGENT_PROVIDER=openrouter

# Model identifier for the chosen provider
# Free options via OpenRouter:
#   nvidia/nemotron-3-super-120b-a12b:free
#   google/gemma-3-27b-it:free
#   meta-llama/llama-3.3-70b-instruct:free
# Paid (better quality):
#   anthropic/claude-3.5-haiku  (via openrouter)
#   anthropic/claude-3.5-sonnet (via openrouter)
AGENT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# API key for the chosen provider
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Anthropic (if AGENT_PROVIDER=anthropic): https://console.anthropic.com
ANTHROPIC_API_KEY=
# OpenAI-compatible (Ollama, Grok, Groq, etc.)
OPENAI_API_KEY=
# Custom OpenAI-compatible base URL (Ollama, Grok, etc.)
# ANTHROPIC_BASE_URL=http://host.docker.internal:11434/v1

# ─── Optional: Telegram Agent Swarm ─────────────────────────────────────────
# Comma-separated tokens for pool bots (for multi-agent teams in Telegram)
# Create 2-5 bots via @BotFather, disable Group Privacy, add to your group
# TELEGRAM_BOT_POOL=TOKEN1,TOKEN2,TOKEN3

# ─── Optional: Assistant Identity ───────────────────────────────────────────
# ASSISTANT_NAME=LearnClaw

# ─── Optional: Performance Tuning ───────────────────────────────────────────
# CONTAINER_TIMEOUT=120000         # ms before agent container is killed (default: 2 min)
# MAX_CONCURRENT_CONTAINERS=3      # parallel agent containers (default: 3)
# IDLE_TIMEOUT=1800000             # ms to keep container alive for IPC (default: 30 min)
# MAX_MESSAGES_PER_PROMPT=10       # chat messages sent to agent per turn (default: 10)
