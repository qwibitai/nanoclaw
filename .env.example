AGENT_BACKEND=claude

# Claude backend
ANTHROPIC_API_KEY=
# Optional for Claude-compatible providers:
# ANTHROPIC_BASE_URL=https://your-api-endpoint.com
# ANTHROPIC_AUTH_TOKEN=

# OpenAI-compatible backend
# AGENT_BACKEND=openai
# AGENT_MODEL=gpt-5
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional for environments with custom/intercepted TLS on web_fetch/web_search:
# WEB_FETCH_INSECURE_TLS=true
# WEB_FETCH_CA_BUNDLE=/path/to/corporate-ca.pem
