
# Credential proxy host override.
# By default NanoClaw binds the credential proxy to the docker0 bridge IP
# (172.17.0.1) so only containers can reach it. On Podman or custom networks
# where docker0 is absent, it falls back to 127.0.0.1.
# Set this to override the bind address explicitly.
# CREDENTIAL_PROXY_HOST=172.17.0.1
