SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# GitHub channel (optional)
# Personal access token with 'repo' scope
GITHUB_TOKEN=
# Default repository for agent (owner/repo format)
GH_REPO=
# Secret configured in GitHub webhook settings
GITHUB_WEBHOOK_SECRET=
# Port for the webhook HTTP server (default: 3002)
GITHUB_WEBHOOK_PORT=3002
# GitHub username of the bot account (used to filter events)
GITHUB_BOT_USERNAME=
