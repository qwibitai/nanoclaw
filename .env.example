# Required — Anthropic API key for Claude agents
ANTHROPIC_API_KEY=

# Required — Vivantio ITSM API
VIVANTIO_API_TOKEN=
VIVANTIO_BASE_URL=https://webservices-na01.vivantio.com
VIVANTIO_AGENT_USER_ID=
VIVANTIO_POLL_INTERVAL=60000
# VIVANTIO_ASSIGNED_GROUP_ID=

# Agent Manager Portal
PORTAL_PORT=3100
PORTAL_JWT_SECRET=change-this-to-a-secure-random-string
PORTAL_ADMIN_EMAIL=admin@blackhawkdata.com
PORTAL_ADMIN_PASSWORD=changeme

# Agent Configuration
ASSISTANT_NAME=BHDAgent
CONTAINER_IMAGE=bhd-itsm-agent:latest
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5
CREDENTIAL_PROXY_PORT=3001
IDLE_TIMEOUT=1800000

# Optional — Alternative auth (OAuth instead of API key)
# CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=

# Optional — Container runtime (default: docker)
# CONTAINER_RUNTIME=docker

# Optional — Timezone for scheduled tasks (default: system timezone)
# TZ=America/Chicago
