# NanoClaw Configuration
# Copy this file to .env and fill in the values you need.

# --- Assistant ---
# ASSISTANT_NAME=Andy
# ASSISTANT_HAS_OWN_NUMBER=false

# --- Agent Backend ---
# Choose how agents run: 'container' (Docker, default) or 'cli' (direct CLI invocation).
# Container mode provides full isolation; CLI mode requires no Docker.
# AGENT_BACKEND=container

# Which CLI tool to use when AGENT_BACKEND=cli: 'claude' or 'cursor'
# AGENT_CLI=claude

# Override the CLI binary path (e.g., /usr/local/bin/claude or /opt/cursor/cursor)
# AGENT_CLI_COMMAND=

# Extra CLI arguments as a comma-separated string (e.g., "--model,sonnet,--verbose")
# AGENT_CLI_EXTRA_ARGS=

# Timeout for CLI agent invocations in milliseconds (default: 600000 = 10 minutes)
# CLI_TIMEOUT=600000

# --- Container Mode ---
# CONTAINER_IMAGE=nanoclaw-agent:latest
# CONTAINER_TIMEOUT=1800000
# CONTAINER_MAX_OUTPUT_SIZE=10485760
# CREDENTIAL_PROXY_PORT=3001
# IDLE_TIMEOUT=1800000
# MAX_CONCURRENT_CONTAINERS=5

# --- API Keys (container mode only — CLI mode uses its own auth) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
