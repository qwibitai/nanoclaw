{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["scripts/*.ts"],
  "project": ["src/**/*.ts", "setup/**/*.ts", "scripts/**/*.ts"],
  "ignoreDependencies": ["pino-pretty", "@vitest/coverage-v8"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "exports": "warn",
    "types": "warn"
  }
}
