#!/bin/sh

# Block ALL commits from the main checkout (not worktrees).
# The policy is "dev work happens in worktrees" — the branch name is irrelevant.
# Even `git checkout -b feature` in the main checkout is a policy violation because
# the main checkout is the running production instance, not a development workspace.
# Part of kAIzen Agent Control Flow — see .claude/kaizen/README.md
#
# Worktrees have git-dir != git-common-dir.
GIT_DIR_PATH=$(git rev-parse --git-dir 2>/dev/null)
GIT_COMMON_PATH=$(git rev-parse --git-common-dir 2>/dev/null)

if [ "$GIT_DIR_PATH" = "$GIT_COMMON_PATH" ]; then
  CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  echo "" >&2
  echo "Blocked: commits in the main checkout are not allowed (branch: $CURRENT_BRANCH)." >&2
  echo "The main checkout is the production instance, not a dev workspace." >&2
  echo "Use a worktree: claude-wt or git worktree add." >&2
  echo "" >&2
  exit 1
fi

# Format only staged .ts files (not all files — avoids dirtying unstaged files)
STAGED_TS=$(git diff --cached --name-only --diff-filter=d -- '*.ts')

if [ -n "$STAGED_TS" ]; then
  echo "$STAGED_TS" | xargs npx prettier --write
  echo "$STAGED_TS" | xargs git add
fi

# Advisory: warn if staged source files have no corresponding test changes (kaizen #15)
STAGED_SRC=$(git diff --cached --name-only --diff-filter=d | \
  grep -E '\.(ts|js|tsx|jsx)$' | \
  grep -vE '(\.test\.|\.spec\.|__tests__|\.config\.|vitest\.|CLAUDE\.md|\.claude/|\.husky/)' || true)

STAGED_TESTS=$(git diff --cached --name-only --diff-filter=d | \
  grep -E '\.(test|spec)\.(ts|js|tsx|jsx)$' || true)

if [ -n "$STAGED_SRC" ] && [ -z "$STAGED_TESTS" ]; then
  SRC_COUNT=$(echo "$STAGED_SRC" | wc -l | tr -d ' ')
  echo "" >&2
  echo "⚠️  $SRC_COUNT source file(s) staged with no test changes:" >&2
  echo "$STAGED_SRC" | sed 's/^/  - /' >&2
  echo "  Consider adding tests before this reaches PR review." >&2
  echo "" >&2
fi
