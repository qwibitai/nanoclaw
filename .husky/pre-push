#!/bin/sh

# Block dev-branch pushes from the main checkout (not worktrees).
# Allows pushing 'main' from the main checkout — this is legitimate
# maintenance (syncing locally-merged commits back to origin).
#
# WHY: Agents merge PRs on GitHub (origin/main advances), then sync
# locally with `git fetch origin main && git merge --ff-only origin/main`.
# Those synced commits need to be pushed back. Blocking main pushes
# causes commits to pile up locally with no way to sync.
#
# Dev branches are still blocked — all dev work must happen in worktrees.
# Part of kAIzen Agent Control Flow — see .claude/kaizen/README.md
#
# Skip in CI — automated workflows (fork-sync, merge-forward) legitimately
# push skill branches from a non-worktree checkout.
if [ "$CI" = "true" ]; then
  exit 0
fi

# Worktrees have git-dir != git-common-dir.
GIT_DIR_PATH=$(git rev-parse --git-dir 2>/dev/null)
GIT_COMMON_PATH=$(git rev-parse --git-common-dir 2>/dev/null)

if [ "$GIT_DIR_PATH" = "$GIT_COMMON_PATH" ]; then
  CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

  # Allow pushing main from the main checkout (post-merge sync)
  if [ "$CURRENT_BRANCH" = "main" ]; then
    exit 0
  fi

  echo "" >&2
  echo "Blocked: pushing branch '$CURRENT_BRANCH' from the main checkout." >&2
  echo "" >&2
  echo "WHY: The main checkout is the production instance. Dev branches" >&2
  echo "must be pushed from worktrees to prevent agents from accidentally" >&2
  echo "pushing untested code from the live environment." >&2
  echo "" >&2
  echo "FIX: Use a worktree for dev work:" >&2
  echo "  claude-wt          # auto-creates isolated worktree" >&2
  echo "  git worktree add   # manual worktree" >&2
  echo "" >&2
  exit 1
fi
