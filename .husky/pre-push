#!/bin/sh

# Block ALL pushes from the main checkout (not worktrees).
# Defense-in-depth: if pre-commit blocks all commits in main checkout,
# there should be nothing to push. This catches --no-verify bypass.
# Part of kAIzen Agent Control Flow — see .claude/kaizen/README.md
#
# Worktrees have git-dir != git-common-dir.
GIT_DIR_PATH=$(git rev-parse --git-dir 2>/dev/null)
GIT_COMMON_PATH=$(git rev-parse --git-common-dir 2>/dev/null)

if [ "$GIT_DIR_PATH" = "$GIT_COMMON_PATH" ]; then
  CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  echo "" >&2
  echo "Blocked: pushes from the main checkout are not allowed (branch: $CURRENT_BRANCH)." >&2
  echo "The main checkout is the production instance, not a dev workspace." >&2
  echo "Use a worktree: claude-wt or git worktree add." >&2
  echo "" >&2
  exit 1
fi
