{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki log datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    },
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "NanoClaw AI agent — Claude API token consumption and cost estimates",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 100000 },
              { "color": "red", "value": 500000 }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Total Tokens Today",
      "description": "Sum of tokens_in + tokens_out for all message_processed events in last 24h",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_in [24h]) + sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_out [24h])",
          "legendFormat": "Total Tokens",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2.0 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Estimated Cost Today",
      "description": "claude-sonnet-4-6: $3/1M input tokens, $15/1M output tokens",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "(sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_in [24h]) * 3 / 1000000) + (sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_out [24h]) * 15 / 1000000)",
          "legendFormat": "Cost USD",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Input Tokens Today",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_in [24h])",
          "legendFormat": "Input Tokens",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Output Tokens Today",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_out [24h])",
          "legendFormat": "Output Tokens",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Input Tokens" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Output Tokens" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Token Usage Over Time (input vs output)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_in [1h])",
          "legendFormat": "Input Tokens",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_out [1h])",
          "legendFormat": "Output Tokens",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Estimated Daily Cost Trend",
      "description": "claude-sonnet-4-6 pricing: $3/1M input, $15/1M output",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "(sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_in [1d]) * 3 / 1000000) + (sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_out [1d]) * 15 / 1000000)",
          "legendFormat": "Daily Cost (USD)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "id": 7,
      "options": {
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" },
        "xField": "group"
      },
      "title": "Token Usage by Group (24h)",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (group) (sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_in [24h])) + sum by (group) (sum_over_time({job=\"nanoclaw\"} | json | event = `message_processed` | unwrap tokens_out [24h]))",
          "legendFormat": "{{group}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["nanoclaw", "observability", "cost"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "DS_LOKI",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource",
        "label": "Loki Datasource"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NanoClaw — Token Usage & Cost",
  "uid": "nanoclaw-tokens",
  "version": 1
}
