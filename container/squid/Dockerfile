# syntax=docker/dockerfile:1.7
# NanoClaw Squid container
#
# Sits between agent containers (on the `nanoclaw-egress` Docker network)
# and the OneCLI gateway (reachable on the host's bridge network). Each
# agent connects to a dedicated TCP port on this container, and per-port
# `myportname` ACLs gate destination domains. Squid forwards all traffic
# through OneCLI via `cache_peer parent ... login=PASSTHRU`, preserving
# the agent's original Proxy-Authorization (the OneCLI per-agent token).
#
# squid.conf is regenerated by the host on every config change and
# bind-mounted into the container at /etc/squid/squid.conf. `squid -k
# reconfigure` reloads without dropping connections.

FROM alpine:3.20

# Pinned to whatever Alpine 3.20 currently ships. Bump when Alpine
# updates the packages — `apk search <name>` from inside an alpine:3.20
# container shows the current versions. (As of 2026-05-11: squid 6.9-r0,
# dnsmasq 2.90-r3.)
ARG SQUID_PACKAGE_VERSION=6.9-r0
ARG DNSMASQ_PACKAGE_VERSION=2.90-r3

RUN apk add --no-cache \
        "squid=${SQUID_PACKAGE_VERSION}" \
        "dnsmasq=${DNSMASQ_PACKAGE_VERSION}" \
        socat \
    && mkdir -p /var/log/squid /var/cache/squid \
    && chown -R squid:squid /var/log/squid /var/cache/squid

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
