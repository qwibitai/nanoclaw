#!/usr/bin/env bash
# text-to-speech: convert text to audio using OpenAI TTS API
# Usage: text-to-speech "text to speak" [voice]
# Voices: alloy, echo, fable, onyx, nova, shimmer (default: onyx)
set -euo pipefail

TEXT="${1:?Usage: text-to-speech \"text to speak\" [voice]}"
VOICE="${2:-onyx}"
OUTPUT_DIR="/workspace/group"
OUTPUT_FILE="${OUTPUT_DIR}/tts-$(date +%s%3N).ogg"

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  echo "ERROR: OPENAI_API_KEY not set" >&2
  exit 1
fi

RESPONSE_CODE=$(curl -sS -w "%{http_code}" -o "$OUTPUT_FILE" \
  -X POST "https://api.openai.com/v1/audio/speech" \
  -H "Authorization: Bearer $OPENAI_API_KEY" \
  -H "Content-Type: application/json" \
  -d "$(python3 -c "
import json, sys
print(json.dumps({
    'model': 'tts-1',
    'input': sys.argv[1],
    'voice': sys.argv[2],
    'response_format': 'opus'
}))
" "$TEXT" "$VOICE")")

if [[ "$RESPONSE_CODE" != "200" ]]; then
  ERROR=$(cat "$OUTPUT_FILE" 2>/dev/null || echo "HTTP $RESPONSE_CODE")
  rm -f "$OUTPUT_FILE"
  echo "ERROR: OpenAI TTS: $ERROR" >&2
  exit 1
fi

# Track via IPC (non-fatal)
{
  IPC_DIR="/workspace/ipc/messages"
  mkdir -p "$IPC_DIR"
  TRACK_FILE="${IPC_DIR}/imgtrack-$(date +%s%3N).json"
  python3 -c "
import json, sys
json.dump({
    'type': 'track_image_gen',
    'gen_type': 'tts',
    'prompt': sys.argv[1][:100],
    'model': 'openai-tts-1',
    'cost_usd': 0.015
}, open(sys.argv[2], 'w'))
" "$TEXT" "$TRACK_FILE"
} || true

echo "$OUTPUT_FILE"
